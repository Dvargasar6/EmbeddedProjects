   1:Core/Src/fsm.c **** /*
   2:Core/Src/fsm.c ****  * fsm.c
   3:Core/Src/fsm.c ****  * Maquina de estados finitos y logica de presentacion del proyecto.
   4:Core/Src/fsm.c ****  *
   5:Core/Src/fsm.c ****  * Arquitectura: productor-consumidor.
   6:Core/Src/fsm.c ****  *   - Productores: las rutinas de interrupcion (UART, TIM4, EXTI, RTC).
   7:Core/Src/fsm.c ****  *     Solo depositan un evento en una cola circular y retornan.
   8:Core/Src/fsm.c ****  *   - Consumidor: fsm_run(), llamado desde el bucle infinito de main().
   9:Core/Src/fsm.c ****  *     Extrae los eventos y ejecuta las transiciones y el refresco del LCD.
  10:Core/Src/fsm.c ****  *
  11:Core/Src/fsm.c ****  * Distribucion de la pantalla de 16x4:
  12:Core/Src/fsm.c ****  *   Fila 0: HH:MM:SS DD-MM
  13:Core/Src/fsm.c ****  *   Fila 1: texto movil, o "MODO X" / "MODO Y", o mensaje temporal
  14:Core/Src/fsm.c ****  *   Fila 2: X:<coordenada> ADC:<muestra cruda>
  15:Core/Src/fsm.c ****  *   Fila 3: Y:<coordenada> ADC:<muestra cruda>
  16:Core/Src/fsm.c ****  */
  17:Core/Src/fsm.c **** #include "fsm.h"
  18:Core/Src/fsm.c **** #include "uart.h"
  19:Core/Src/fsm.c **** #include "i2c_lcd.h"
  20:Core/Src/fsm.c **** #include "rtc.h"
  21:Core/Src/fsm.c **** #include "adc_joystick.h"
  22:Core/Src/fsm.c **** #include "system_clock.h"
  23:Core/Src/fsm.c **** 
  24:Core/Src/fsm.c **** /* Bandera del segundo, definida en rtc.c */
  25:Core/Src/fsm.c **** extern volatile uint8_t g_rtc_second_flag;
  26:Core/Src/fsm.c **** 
  27:Core/Src/fsm.c **** /* ======================= Cola circular de eventos ======================= */
  28:Core/Src/fsm.c **** #define EVQ_SIZE  32U   /* holgado: los eventos se consumen en pocos ms */
  29:Core/Src/fsm.c **** 
  30:Core/Src/fsm.c **** static volatile fsm_event_t s_evq[EVQ_SIZE];
  31:Core/Src/fsm.c **** static volatile uint8_t     s_evq_head = 0;   /* escribe la ISR   */
ARM GAS  /tmp/ccgN4EYJ.s 			page 2


  32:Core/Src/fsm.c **** static volatile uint8_t     s_evq_tail = 0;   /* lee el bucle main */
  33:Core/Src/fsm.c **** 
  34:Core/Src/fsm.c **** /* ======================= Variables de estado ============================ */
  35:Core/Src/fsm.c **** static fsm_state_t s_state = ST_INIT;
  36:Core/Src/fsm.c **** static fsm_state_t s_prev  = ST_IDLE;   /* estado al que volver tras un mensaje */
  37:Core/Src/fsm.c **** 
  38:Core/Src/fsm.c **** /* Coordenadas gobernadas conjuntamente por el joystick y por la UART */
  39:Core/Src/fsm.c **** static int16_t s_coord_x = 0;
  40:Core/Src/fsm.c **** static int16_t s_coord_y = 0;
  41:Core/Src/fsm.c **** 
  42:Core/Src/fsm.c **** #define COORD_MIN  (-999)
  43:Core/Src/fsm.c **** #define COORD_MAX  ( 999)
  44:Core/Src/fsm.c **** 
  45:Core/Src/fsm.c **** /* Texto de la fila 1 y desplazamiento actual del efecto de marquesina */
  46:Core/Src/fsm.c **** static const char *s_line2 = NULL;
  47:Core/Src/fsm.c **** static uint16_t    s_scroll = 0;
  48:Core/Src/fsm.c **** 
  49:Core/Src/fsm.c **** /* Copia de lo ultimo escrito en cada fila. Evita reenviar por I2C una linea
  50:Core/Src/fsm.c ****    que no ha cambiado: escribir una fila cuesta unos 7 ms, de modo que
  51:Core/Src/fsm.c ****    refrescar las cuatro sin necesidad consumiria una tercera parte del
  52:Core/Src/fsm.c ****    periodo de 100 ms sin aportar nada. */
  53:Core/Src/fsm.c **** static char s_shadow[LCD_ROWS][LCD_COLS + 1U];
  54:Core/Src/fsm.c **** 
  55:Core/Src/fsm.c **** /* Contadores de reparto de tareas, en unidades de 100 ms */
  56:Core/Src/fsm.c **** static uint16_t s_tick_scroll  = 0;   /* desplaza el texto cada 300 ms */
  57:Core/Src/fsm.c **** static uint16_t s_msg_timeout  = 0;   /* vida restante del mensaje temporal */
  58:Core/Src/fsm.c **** 
  59:Core/Src/fsm.c **** /* Textos fijos */
  60:Core/Src/fsm.c **** static const char TXT_BANNER[]  = "DANIEL FELIPE VARGAS ARIAS - PARCIAL TALLER V 2026-1 - UNAL";
  61:Core/Src/fsm.c **** static const char TXT_MODE_X[]  = "MODO X";
  62:Core/Src/fsm.c **** static const char TXT_MODE_Y[]  = "MODO Y";
  63:Core/Src/fsm.c **** static const char TXT_NO_MODE[] = "ACTIVAR UN MODO";
  64:Core/Src/fsm.c **** 
  65:Core/Src/fsm.c **** #define MSG_DURATION_TICKS  30U   /* 30 * 100 ms = 3 s */
  66:Core/Src/fsm.c **** 
  67:Core/Src/fsm.c **** /* ======================= Cola de eventos ================================ */
  68:Core/Src/fsm.c **** 
  69:Core/Src/fsm.c **** /*
  70:Core/Src/fsm.c ****  * fsm_post_event
  71:Core/Src/fsm.c ****  * Deposita un evento. Es la unica funcion del modulo que pueden invocar las
  72:Core/Src/fsm.c ****  * rutinas de interrupcion. Si la cola esta llena el evento se descarta, lo
  73:Core/Src/fsm.c ****  * que es preferible a bloquear una ISR.
  74:Core/Src/fsm.c ****  */
  75:Core/Src/fsm.c **** void fsm_post_event(fsm_event_t ev)
  76:Core/Src/fsm.c **** {
  77:Core/Src/fsm.c ****     uint8_t next = (uint8_t)((s_evq_head + 1U) % EVQ_SIZE);
  78:Core/Src/fsm.c **** 
  79:Core/Src/fsm.c ****     if (next == s_evq_tail) {
  80:Core/Src/fsm.c ****         return;   /* cola llena */
  81:Core/Src/fsm.c ****     }
  82:Core/Src/fsm.c ****     s_evq[s_evq_head] = ev;
  83:Core/Src/fsm.c ****     s_evq_head = next;
  84:Core/Src/fsm.c **** }
  85:Core/Src/fsm.c **** 
