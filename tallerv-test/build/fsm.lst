 148:Core/Src/fsm.c **** /*
 149:Core/Src/fsm.c ****  * render_line2
 150:Core/Src/fsm.c ****  * Compone la ventana de 16 caracteres visible de la fila 1.
 151:Core/Src/fsm.c ****  * Si el texto cabe entero se muestra fijo; si no, se desplaza ciclicamente
 152:Core/Src/fsm.c ****  * anadiendo un separador de tres espacios entre el final y el principio.
 153:Core/Src/fsm.c ****  */
 154:Core/Src/fsm.c **** static void render_line2(void)
 155:Core/Src/fsm.c **** {
 156:Core/Src/fsm.c ****     char     win[LCD_COLS + 1U];
 157:Core/Src/fsm.c ****     uint16_t len, total, i, idx;
 158:Core/Src/fsm.c **** 
 159:Core/Src/fsm.c ****     if (s_line2 == NULL) {
 160:Core/Src/fsm.c ****         return;
 161:Core/Src/fsm.c ****     }
 162:Core/Src/fsm.c **** 
 163:Core/Src/fsm.c ****     len = (uint16_t)strlen(s_line2);
 164:Core/Src/fsm.c **** 
 165:Core/Src/fsm.c ****     if (len <= LCD_COLS) {
 166:Core/Src/fsm.c ****         lcd_update(1U, s_line2);   /* cabe entero: sin desplazamiento */
 167:Core/Src/fsm.c ****         return;
 168:Core/Src/fsm.c ****     }
 169:Core/Src/fsm.c **** 
 170:Core/Src/fsm.c ****     total = (uint16_t)(len + 3U);      /* longitud del ciclo con separador */
 171:Core/Src/fsm.c **** 
 172:Core/Src/fsm.c ****     for (i = 0U; i < LCD_COLS; i++) {
 173:Core/Src/fsm.c ****         idx = (uint16_t)((s_scroll + i) % total);
 174:Core/Src/fsm.c ****         win[i] = (idx < len) ? s_line2[idx] : ' ';
 175:Core/Src/fsm.c ****     }
 176:Core/Src/fsm.c ****     win[LCD_COLS] = '\0';
 177:Core/Src/fsm.c **** 
 178:Core/Src/fsm.c ****     lcd_update(1U, win);
 179:Core/Src/fsm.c **** }
 180:Core/Src/fsm.c **** 
