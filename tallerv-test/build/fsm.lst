 115:Core/Src/fsm.c **** /*
 116:Core/Src/fsm.c ****  * lcd_update
 117:Core/Src/fsm.c ****  * Escribe una fila solo si su contenido difiere del ultimo enviado.
 118:Core/Src/fsm.c ****  */
 119:Core/Src/fsm.c **** static void lcd_update(uint8_t row, const char *txt)
 120:Core/Src/fsm.c **** {
 121:Core/Src/fsm.c ****     char norm[LCD_COLS + 1U];
 122:Core/Src/fsm.c ****     uint8_t i, end = 0U;
 123:Core/Src/fsm.c **** 
 124:Core/Src/fsm.c ****     /* Normaliza a 16 caracteres exactos para que la comparacion sea fiable */
 125:Core/Src/fsm.c ****     for (i = 0U; i < LCD_COLS; i++) {
 126:Core/Src/fsm.c ****         if (!end && (txt[i] == '\0')) end = 1U;
 127:Core/Src/fsm.c ****         norm[i] = end ? ' ' : txt[i];
 128:Core/Src/fsm.c ****     }
 129:Core/Src/fsm.c ****     norm[LCD_COLS] = '\0';
 130:Core/Src/fsm.c **** 
 131:Core/Src/fsm.c ****     if (strncmp(norm, s_shadow[row], LCD_COLS) == 0) {
 132:Core/Src/fsm.c ****         return;                       /* sin cambios: no se toca el bus */
 133:Core/Src/fsm.c ****     }
 134:Core/Src/fsm.c ****     memcpy(s_shadow[row], norm, LCD_COLS + 1U);
 135:Core/Src/fsm.c ****     lcd_print_line(row, norm);
 136:Core/Src/fsm.c **** }
 137:Core/Src/fsm.c **** 
