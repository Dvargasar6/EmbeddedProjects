 242:Core/Src/fsm.c **** 
 243:Core/Src/fsm.c **** /* ======================= Acciones sobre las coordenadas ================= */
 244:Core/Src/fsm.c **** 
 245:Core/Src/fsm.c **** /*
 246:Core/Src/fsm.c ****  * coord_step
 247:Core/Src/fsm.c ****  * Aplica un incremento a la coordenada del modo activo. Si no hay modo
 248:Core/Src/fsm.c ****  * seleccionado emite el aviso exigido por el enunciado.
 249:Core/Src/fsm.c ****  */
 250:Core/Src/fsm.c **** static void coord_step(int16_t delta)
 251:Core/Src/fsm.c **** {
 252:Core/Src/fsm.c ****     switch (s_state) {
 253:Core/Src/fsm.c **** 
 254:Core/Src/fsm.c ****     case ST_MODE_X:
 255:Core/Src/fsm.c ****         s_coord_x = clamp_coord((int32_t)s_coord_x + delta);
 256:Core/Src/fsm.c ****         render_coords();
 257:Core/Src/fsm.c ****         break;
 258:Core/Src/fsm.c **** 
 259:Core/Src/fsm.c ****     case ST_MODE_Y:
 260:Core/Src/fsm.c ****         s_coord_y = clamp_coord((int32_t)s_coord_y + delta);
 261:Core/Src/fsm.c ****         render_coords();
 262:Core/Src/fsm.c ****         break;
 263:Core/Src/fsm.c **** 
 264:Core/Src/fsm.c ****     case ST_MESSAGE:
 265:Core/Src/fsm.c ****         /* Si ya se esta mostrando el aviso se prolonga su duracion, salvo que
 266:Core/Src/fsm.c ****            el modo memorizado sea valido, en cuyo caso se aplica el paso. */
 267:Core/Src/fsm.c ****         if (s_prev == ST_MODE_X) {
 268:Core/Src/fsm.c ****             s_coord_x = clamp_coord((int32_t)s_coord_x + delta);
 269:Core/Src/fsm.c ****             render_coords();
 270:Core/Src/fsm.c ****         } else if (s_prev == ST_MODE_Y) {
 271:Core/Src/fsm.c ****             s_coord_y = clamp_coord((int32_t)s_coord_y + delta);
 272:Core/Src/fsm.c ****             render_coords();
 273:Core/Src/fsm.c ****         } else {
 274:Core/Src/fsm.c ****             s_msg_timeout = MSG_DURATION_TICKS;
 275:Core/Src/fsm.c ****         }
 276:Core/Src/fsm.c ****         break;
 277:Core/Src/fsm.c **** 
 278:Core/Src/fsm.c ****     default:
 279:Core/Src/fsm.c ****         show_message(TXT_NO_MODE);
 280:Core/Src/fsm.c ****         uart_send_line("ERROR: seleccione modo con 'x' o 'y'");
 281:Core/Src/fsm.c ****         break;
 282:Core/Src/fsm.c ****     }
 283:Core/Src/fsm.c **** }
 284:Core/Src/fsm.c **** 
 285:Core/Src/fsm.c **** /*
 286:Core/Src/fsm.c ****  * apply_joystick
 287:Core/Src/fsm.c ****  * Traduce la posicion del joystick en incrementos de coordenada. Se ejecuta
 288:Core/Src/fsm.c ****  * cada 100 ms, de modo que mantener la palanca desviada produce un barrido
 289:Core/Src/fsm.c ****  * continuo de 10 unidades por segundo.
 290:Core/Src/fsm.c ****  */
 291:Core/Src/fsm.c **** static void apply_joystick(void)
ARM GAS  /tmp/ccgN4EYJ.s 			page 21


 292:Core/Src/fsm.c **** {
 293:Core/Src/fsm.c ****     int8_t dx = adc_joystick_dir_x();
 294:Core/Src/fsm.c ****     int8_t dy = adc_joystick_dir_y();
 295:Core/Src/fsm.c **** 
 296:Core/Src/fsm.c ****     if (dx != 0) {
 297:Core/Src/fsm.c ****         s_coord_x = clamp_coord((int32_t)s_coord_x + dx);
 298:Core/Src/fsm.c ****     }
 299:Core/Src/fsm.c ****     if (dy != 0) {
 300:Core/Src/fsm.c ****         s_coord_y = clamp_coord((int32_t)s_coord_y + dy);
 301:Core/Src/fsm.c ****     }
 302:Core/Src/fsm.c **** }
 303:Core/Src/fsm.c **** 
