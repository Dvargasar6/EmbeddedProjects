   1:Core/Src/system_clock.c **** /*
   2:Core/Src/system_clock.c ****  * system_clock.c
   3:Core/Src/system_clock.c ****  * Configuracion del arbol de relojes del STM32F411RE y de la salida MCO1.
   4:Core/Src/system_clock.c ****  *
   5:Core/Src/system_clock.c ****  * Cadena de reloj implementada:
   6:Core/Src/system_clock.c ****  *
   7:Core/Src/system_clock.c ****  *   HSI (16 MHz) --> /PLLM=8 --> 2 MHz --> xPLLN=100 --> VCO 200 MHz
   8:Core/Src/system_clock.c ****  *                                                  --> /PLLP=2 --> 100 MHz = SYSCLK
   9:Core/Src/system_clock.c ****  *
  10:Core/Src/system_clock.c ****  *   AHB  = SYSCLK / 1 = 100 MHz   (limite del F411: 100 MHz)
  11:Core/Src/system_clock.c ****  *   APB1 = SYSCLK / 2 =  50 MHz   (limite del F411:  50 MHz)
  12:Core/Src/system_clock.c ****  *   APB2 = SYSCLK / 1 = 100 MHz   (limite del F411: 100 MHz)
  13:Core/Src/system_clock.c ****  *
  14:Core/Src/system_clock.c ****  * Se elige HSI y no HSE como fuente del PLL por dos razones:
  15:Core/Src/system_clock.c ****  *   1. El LED exigido esta en PH1, que es el pin OSC_OUT del HSE. Usando HSI
  16:Core/Src/system_clock.c ****  *      el puerto GPIOH queda completamente libre.
  17:Core/Src/system_clock.c ****  *   2. En la Nucleo-F411RE el HSE proviene del MCO del ST-LINK (8 MHz) y
  18:Core/Src/system_clock.c ****  *      depende de la configuracion de los puentes SB54/SB55.
  19:Core/Src/system_clock.c ****  */
  20:Core/Src/system_clock.c **** #include "system_clock.h"
  21:Core/Src/system_clock.c **** 
  22:Core/Src/system_clock.c **** /* Fuente actualmente enrutada a MCO1. Estatica: solo visible en este archivo. */
  23:Core/Src/system_clock.c **** static mco_src_t s_mco_src = MCO_SRC_PLL;
  24:Core/Src/system_clock.c **** 
  25:Core/Src/system_clock.c **** /* Frecuencia real medida en PA8 tras aplicar el prescaler, en hercios. */
  26:Core/Src/system_clock.c **** static uint32_t  s_mco_freq = 20000000U;
  27:Core/Src/system_clock.c **** 
  28:Core/Src/system_clock.c **** /* 1 si el cristal LSE arranco correctamente; 0 si no esta montado o no oscila */
  29:Core/Src/system_clock.c **** static uint8_t   s_lse_ok = 0;
ARM GAS  /tmp/cc6RsDJF.s 			page 2


  30:Core/Src/system_clock.c **** 
  31:Core/Src/system_clock.c **** /*
  32:Core/Src/system_clock.c ****  * system_clock_init
  33:Core/Src/system_clock.c ****  * Configura la alimentacion, la latencia de FLASH, los osciladores y los buses.
  34:Core/Src/system_clock.c ****  * Debe llamarse inmediatamente despues de HAL_Init() y antes de cualquier
  35:Core/Src/system_clock.c ****  * inicializacion de periferico.
  36:Core/Src/system_clock.c ****  */
  37:Core/Src/system_clock.c **** void system_clock_init(void)
  38:Core/Src/system_clock.c **** {
  39:Core/Src/system_clock.c ****     RCC_OscInitTypeDef       osc = {0};   /* configuracion de osciladores */
  40:Core/Src/system_clock.c ****     RCC_ClkInitTypeDef       clk = {0};   /* configuracion de buses       */
  41:Core/Src/system_clock.c **** 
  42:Core/Src/system_clock.c ****     /* --- 1. Alimentacion del regulador interno -------------------------- */
  43:Core/Src/system_clock.c ****     /* Habilita el reloj del bloque PWR: sin el no se puede escribir en PWR->CR */
  44:Core/Src/system_clock.c ****     __HAL_RCC_PWR_CLK_ENABLE();
  45:Core/Src/system_clock.c **** 
  46:Core/Src/system_clock.c ****     /* Escala de voltaje 1: unica que admite 100 MHz en el F411.
  47:Core/Src/system_clock.c ****        Alternativas: SCALE2 (hasta 84 MHz) y SCALE3 (hasta 64 MHz), que
  48:Core/Src/system_clock.c ****        consumen menos corriente pero limitan la frecuencia maxima. */
  49:Core/Src/system_clock.c ****     __HAL_PWR_VOLTAGESCALING_CONFIG(PWR_REGULATOR_VOLTAGE_SCALE1);
  50:Core/Src/system_clock.c **** 
  51:Core/Src/system_clock.c ****     /* Permite escribir en el dominio de respaldo (Backup Domain), necesario
  52:Core/Src/system_clock.c ****        para arrancar el LSE y para configurar el RTC. */
  53:Core/Src/system_clock.c ****     HAL_PWR_EnableBkUpAccess();
  54:Core/Src/system_clock.c **** 
  55:Core/Src/system_clock.c ****     /* --- 2. Oscilador HSI y PLL (critico) ------------------------------- */
  56:Core/Src/system_clock.c ****     /* El LSE se configura APARTE, mas abajo. Motivo: muchas placas
  57:Core/Src/system_clock.c ****        NUCLEO-F411RE se sirven sin el cristal X2 de 32.768 kHz montado. Si el
  58:Core/Src/system_clock.c ****        LSE se configurase en la misma llamada, su fallo abortaria tambien la
  59:Core/Src/system_clock.c ****        configuracion del PLL y el sistema entero quedaria detenido en
  60:Core/Src/system_clock.c ****        Error_Handler, sin LCD, sin UART y sin LED de 250 ms. */
  61:Core/Src/system_clock.c ****     osc.OscillatorType      = RCC_OSCILLATORTYPE_HSI;
  62:Core/Src/system_clock.c ****     osc.HSIState            = RCC_HSI_ON;              /* enciende el HSI     */
  63:Core/Src/system_clock.c ****     osc.HSICalibrationValue = RCC_HSICALIBRATION_DEFAULT; /* trim de fabrica  */
  64:Core/Src/system_clock.c **** 
  65:Core/Src/system_clock.c ****     osc.PLL.PLLState        = RCC_PLL_ON;              /* activa el PLL       */
  66:Core/Src/system_clock.c ****     osc.PLL.PLLSource       = RCC_PLLSOURCE_HSI;       /* entrada del PLL     */
  67:Core/Src/system_clock.c ****     osc.PLL.PLLM            = 8U;    /* divisor de entrada: 16 MHz / 8 = 2 MHz.
  68:Core/Src/system_clock.c ****                                         La entrada al VCO debe quedar entre
  69:Core/Src/system_clock.c ****                                         1 y 2 MHz; 2 MHz minimiza el jitter */
  70:Core/Src/system_clock.c ****     osc.PLL.PLLN            = 100U;  /* multiplicador: 2 MHz * 100 = 200 MHz.
  71:Core/Src/system_clock.c ****                                         El VCO debe quedar entre 100 y 432 MHz */
  72:Core/Src/system_clock.c ****     osc.PLL.PLLP            = RCC_PLLP_DIV2; /* 200 MHz / 2 = 100 MHz = SYSCLK.
  73:Core/Src/system_clock.c ****                                         Valores posibles: DIV2, DIV4, DIV6, DIV8 */
  74:Core/Src/system_clock.c ****     osc.PLL.PLLQ            = 4U;    /* rama para USB/SDIO: 200 MHz / 4 = 50 MHz.
  75:Core/Src/system_clock.c ****                                         No se usa en este proyecto, pero la HAL
  76:Core/Src/system_clock.c ****                                         exige un valor valido (2..15) */
  77:Core/Src/system_clock.c **** 
  78:Core/Src/system_clock.c ****     if (HAL_RCC_OscConfig(&osc) != HAL_OK) {
  79:Core/Src/system_clock.c ****         Error_Handler();             /* fallo del PLL: este si es irrecuperable */
  80:Core/Src/system_clock.c ****     }
  81:Core/Src/system_clock.c **** 
  82:Core/Src/system_clock.c ****     /* --- 3. Buses del sistema ------------------------------------------- */
  83:Core/Src/system_clock.c ****     /* Se indican los cuatro relojes que se van a modificar */
  84:Core/Src/system_clock.c ****     clk.ClockType      = RCC_CLOCKTYPE_HCLK   | RCC_CLOCKTYPE_SYSCLK |
  85:Core/Src/system_clock.c ****                          RCC_CLOCKTYPE_PCLK1  | RCC_CLOCKTYPE_PCLK2;
  86:Core/Src/system_clock.c ****     clk.SYSCLKSource   = RCC_SYSCLKSOURCE_PLLCLK; /* el PLL alimenta el sistema */
ARM GAS  /tmp/cc6RsDJF.s 			page 3


  87:Core/Src/system_clock.c ****     clk.AHBCLKDivider  = RCC_SYSCLK_DIV1;         /* HCLK  = 100 MHz            */
  88:Core/Src/system_clock.c ****     clk.APB1CLKDivider = RCC_HCLK_DIV2;           /* PCLK1 =  50 MHz (maximo)   */
  89:Core/Src/system_clock.c ****     clk.APB2CLKDivider = RCC_HCLK_DIV1;           /* PCLK2 = 100 MHz            */
  90:Core/Src/system_clock.c **** 
  91:Core/Src/system_clock.c ****     /* FLASH_LATENCY_3 = 3 estados de espera.
  92:Core/Src/system_clock.c ****        A 3.3 V la FLASH admite 30 MHz por estado de espera:
  93:Core/Src/system_clock.c ****          0 WS <= 30 MHz, 1 WS <= 60 MHz, 2 WS <= 90 MHz, 3 WS <= 100 MHz.
  94:Core/Src/system_clock.c ****        Un valor menor al necesario provoca lecturas erroneas de instrucciones. */
  95:Core/Src/system_clock.c ****     if (HAL_RCC_ClockConfig(&clk, FLASH_LATENCY_3) != HAL_OK) {
  96:Core/Src/system_clock.c ****         Error_Handler();
  97:Core/Src/system_clock.c ****     }
  98:Core/Src/system_clock.c **** 
  99:Core/Src/system_clock.c ****     /* Actualiza la variable global SystemCoreClock y reprograma el SysTick
 100:Core/Src/system_clock.c ****        para que siga generando interrupciones cada 1 ms con el nuevo HCLK. */
 101:Core/Src/system_clock.c ****     SystemCoreClockUpdate();
 102:Core/Src/system_clock.c ****     HAL_InitTick(TICK_INT_PRIORITY);
 103:Core/Src/system_clock.c **** 
 104:Core/Src/system_clock.c ****     /* --- 4. Cristal LSE de 32.768 kHz (NO critico) ----------------------- */
 105:Core/Src/system_clock.c ****     /* Se intenta arrancar por separado. Si el cristal no esta montado o no
 106:Core/Src/system_clock.c ****        oscila, la llamada agota LSE_STARTUP_TIMEOUT (5 s por defecto) y
 107:Core/Src/system_clock.c ****        devuelve error, pero el sistema CONTINUA: el RTC recurrira al LSI y el
 108:Core/Src/system_clock.c ****        resto de funciones queda intacto. El diagnostico se emite por UART. */
 109:Core/Src/system_clock.c ****     osc.OscillatorType = RCC_OSCILLATORTYPE_LSE;
 110:Core/Src/system_clock.c ****     osc.PLL.PLLState   = RCC_PLL_NONE;   /* no volver a tocar el PLL ya activo */
 111:Core/Src/system_clock.c ****     osc.LSEState       = RCC_LSE_ON;
 112:Core/Src/system_clock.c ****     /* Alternativa: RCC_LSE_BYPASS si se inyecta un reloj externo ya generado */
 113:Core/Src/system_clock.c **** 
 114:Core/Src/system_clock.c ****     s_lse_ok = (HAL_RCC_OscConfig(&osc) == HAL_OK) ? 1U : 0U;
 115:Core/Src/system_clock.c **** 
 116:Core/Src/system_clock.c ****     if (!s_lse_ok) {
 117:Core/Src/system_clock.c ****         /* Reserva: oscilador interno de baja velocidad. Permite que el RTC
 118:Core/Src/system_clock.c ****            siga contando y que el equipo sea diagnosticable, pero NO cumple el
 119:Core/Src/system_clock.c ****            enunciado: el LSI se detiene al desaparecer VDD, de modo que la
 120:Core/Src/system_clock.c ****            hora no sobrevive a la perdida de alimentacion. La causa debe
 121:Core/Src/system_clock.c ****            corregirse en el hardware (cristal X2 y puentes SB48/SB49). */
 122:Core/Src/system_clock.c ****         osc.OscillatorType = RCC_OSCILLATORTYPE_LSI;
 123:Core/Src/system_clock.c ****         osc.PLL.PLLState   = RCC_PLL_NONE;
 124:Core/Src/system_clock.c ****         osc.LSIState       = RCC_LSI_ON;
 125:Core/Src/system_clock.c ****         HAL_RCC_OscConfig(&osc);
 126:Core/Src/system_clock.c ****     }
 127:Core/Src/system_clock.c **** 
 128:Core/Src/system_clock.c ****     /* --- 5. Salida MCO1 por defecto ------------------------------------- */
 129:Core/Src/system_clock.c ****     system_clock_mco_set(MCO_SRC_PLL);
 130:Core/Src/system_clock.c **** }
