   1:Core/Src/adc_joystick.c **** /*
   2:Core/Src/adc_joystick.c ****  * adc_joystick.c
   3:Core/Src/adc_joystick.c ****  * Adquisicion de los dos ejes del joystick con ADC1 en modo interrupcion.
   4:Core/Src/adc_joystick.c ****  *
   5:Core/Src/adc_joystick.c ****  * Estrategia: el ADC del STM32F4 dispone de un unico registro de datos. Para
   6:Core/Src/adc_joystick.c ****  * leer dos canales sin DMA se convierte de uno en uno y se conmuta el canal
   7:Core/Src/adc_joystick.c ****  * dentro del callback de fin de conversion:
   8:Core/Src/adc_joystick.c ****  *
   9:Core/Src/adc_joystick.c ****  *   TIM4 (100 ms) --> adc_joystick_start() --> conversion canal IN0
  10:Core/Src/adc_joystick.c ****  *          callback --> guarda VRX, selecciona IN1, arranca de nuevo
  11:Core/Src/adc_joystick.c ****  *          callback --> guarda VRY, secuencia terminada
  12:Core/Src/adc_joystick.c ****  *
  13:Core/Src/adc_joystick.c ****  * De este modo no hay ninguna espera activa: el nucleo solo interviene
  14:Core/Src/adc_joystick.c ****  * durante los pocos microsegundos de cada interrupcion.
  15:Core/Src/adc_joystick.c ****  */
  16:Core/Src/adc_joystick.c **** #include "adc_joystick.h"
  17:Core/Src/adc_joystick.c **** 
  18:Core/Src/adc_joystick.c **** ADC_HandleTypeDef hadc1;
  19:Core/Src/adc_joystick.c **** 
  20:Core/Src/adc_joystick.c **** /* Indice del canal en curso: 0 = VRX (IN0), 1 = VRY (IN1). volatile porque
  21:Core/Src/adc_joystick.c ****    se modifica dentro de una interrupcion y se lee fuera de ella. */
  22:Core/Src/adc_joystick.c **** static volatile uint8_t  s_channel = 0;
  23:Core/Src/adc_joystick.c **** 
  24:Core/Src/adc_joystick.c **** /* Ultimas muestras validas de cada eje */
  25:Core/Src/adc_joystick.c **** static volatile uint16_t s_raw_x = JOY_CENTER;
  26:Core/Src/adc_joystick.c **** static volatile uint16_t s_raw_y = JOY_CENTER;
  27:Core/Src/adc_joystick.c **** 
  28:Core/Src/adc_joystick.c **** /*
  29:Core/Src/adc_joystick.c ****  * adc_select_channel
  30:Core/Src/adc_joystick.c ****  * Programa el canal que ocupara el primer puesto de la secuencia de conversion.
ARM GAS  /tmp/ccPzv4Jy.s 			page 2


  31:Core/Src/adc_joystick.c ****  * Funcion interna (static): no forma parte de la interfaz del modulo.
  32:Core/Src/adc_joystick.c ****  */
  33:Core/Src/adc_joystick.c **** static void adc_select_channel(uint8_t idx)
  34:Core/Src/adc_joystick.c **** {
  35:Core/Src/adc_joystick.c ****     ADC_ChannelConfTypeDef ch = {0};
  36:Core/Src/adc_joystick.c **** 
  37:Core/Src/adc_joystick.c ****     ch.Channel      = (idx == 0) ? ADC_CHANNEL_0 : ADC_CHANNEL_1;
  38:Core/Src/adc_joystick.c ****     ch.Rank         = 1;   /* primera y unica posicion de la secuencia */
  39:Core/Src/adc_joystick.c ****     ch.SamplingTime = ADC_SAMPLETIME_84CYCLES;
  40:Core/Src/adc_joystick.c ****     /* Tiempo de muestreo: 84 ciclos de ADCCLK. Debe ser suficiente para que el
  41:Core/Src/adc_joystick.c ****        condensador de muestreo se cargue a traves de la impedancia de la fuente.
  42:Core/Src/adc_joystick.c ****        El potenciometro del joystick ronda los 10 kohm, valor alto, por lo que
  43:Core/Src/adc_joystick.c ****        se toma un tiempo generoso. Alternativas: 3, 15, 28, 56, 112, 144, 480
  44:Core/Src/adc_joystick.c ****        ciclos. Un tiempo demasiado corto produce lecturas bajas y ruidosas. */
  45:Core/Src/adc_joystick.c **** 
  46:Core/Src/adc_joystick.c ****     if (HAL_ADC_ConfigChannel(&hadc1, &ch) != HAL_OK) {
  47:Core/Src/adc_joystick.c ****         Error_Handler();
  48:Core/Src/adc_joystick.c ****     }
  49:Core/Src/adc_joystick.c **** }
  50:Core/Src/adc_joystick.c **** 
  51:Core/Src/adc_joystick.c **** void adc_joystick_init(void)
  52:Core/Src/adc_joystick.c **** {
  53:Core/Src/adc_joystick.c ****     __HAL_RCC_ADC1_CLK_ENABLE();   /* reloj del ADC1 (bus APB2) */
  54:Core/Src/adc_joystick.c **** 
  55:Core/Src/adc_joystick.c ****     hadc1.Instance = ADC1;
  56:Core/Src/adc_joystick.c **** 
  57:Core/Src/adc_joystick.c ****     /* ADCCLK = PCLK2 / 4 = 100 MHz / 4 = 25 MHz.
  58:Core/Src/adc_joystick.c ****        El maximo admitido por el ADC del F411 es 36 MHz; DIV2 daria 50 MHz y
  59:Core/Src/adc_joystick.c ****        violaria la especificacion. Alternativas: DIV2, DIV4, DIV6, DIV8. */
  60:Core/Src/adc_joystick.c ****     hadc1.Init.ClockPrescaler = ADC_CLOCK_SYNC_PCLK_DIV4;
  61:Core/Src/adc_joystick.c **** 
  62:Core/Src/adc_joystick.c ****     hadc1.Init.Resolution = ADC_RESOLUTION_12B;  /* 0..4095. Alternativas:
  63:Core/Src/adc_joystick.c ****                                         10B, 8B, 6B; menor resolucion implica
  64:Core/Src/adc_joystick.c ****                                         conversiones mas rapidas */
  65:Core/Src/adc_joystick.c ****     hadc1.Init.ScanConvMode          = DISABLE;  /* un solo canal por secuencia */
  66:Core/Src/adc_joystick.c ****     hadc1.Init.ContinuousConvMode    = DISABLE;  /* conversion unica bajo demanda */
  67:Core/Src/adc_joystick.c ****     hadc1.Init.DiscontinuousConvMode = DISABLE;
  68:Core/Src/adc_joystick.c ****     hadc1.Init.ExternalTrigConv      = ADC_SOFTWARE_START;
  69:Core/Src/adc_joystick.c ****                                         /* el disparo lo da el software desde
  70:Core/Src/adc_joystick.c ****                                            la ISR de TIM4. Alternativa: disparo
  71:Core/Src/adc_joystick.c ****                                            directo por TRGO de un temporizador */
  72:Core/Src/adc_joystick.c ****     hadc1.Init.ExternalTrigConvEdge  = ADC_EXTERNALTRIGCONVEDGE_NONE;
  73:Core/Src/adc_joystick.c ****     hadc1.Init.DataAlign             = ADC_DATAALIGN_RIGHT;
  74:Core/Src/adc_joystick.c ****                                         /* resultado justificado a la derecha:
  75:Core/Src/adc_joystick.c ****                                            el valor se lee directamente sin
  76:Core/Src/adc_joystick.c ****                                            desplazamientos */
  77:Core/Src/adc_joystick.c ****     hadc1.Init.NbrOfConversion       = 1;
  78:Core/Src/adc_joystick.c ****     hadc1.Init.DMAContinuousRequests = DISABLE;
  79:Core/Src/adc_joystick.c ****     hadc1.Init.EOCSelection          = ADC_EOC_SINGLE_CONV;
  80:Core/Src/adc_joystick.c ****                                         /* la bandera EOC se activa al terminar
  81:Core/Src/adc_joystick.c ****                                            cada conversion individual */
  82:Core/Src/adc_joystick.c **** 
  83:Core/Src/adc_joystick.c ****     if (HAL_ADC_Init(&hadc1) != HAL_OK) {
  84:Core/Src/adc_joystick.c ****         Error_Handler();
  85:Core/Src/adc_joystick.c ****     }
  86:Core/Src/adc_joystick.c **** 
  87:Core/Src/adc_joystick.c ****     adc_select_channel(0);   /* deja seleccionado VRX para la primera lectura */
ARM GAS  /tmp/ccPzv4Jy.s 			page 3


  88:Core/Src/adc_joystick.c **** 
  89:Core/Src/adc_joystick.c ****     /* Prioridad 6: por debajo de la UART, por encima de los temporizadores */
  90:Core/Src/adc_joystick.c ****     HAL_NVIC_SetPriority(ADC_IRQn, 6, 0);
  91:Core/Src/adc_joystick.c ****     HAL_NVIC_EnableIRQ(ADC_IRQn);
  92:Core/Src/adc_joystick.c **** }
  93:Core/Src/adc_joystick.c **** 
  94:Core/Src/adc_joystick.c **** /*
  95:Core/Src/adc_joystick.c ****  * adc_joystick_start
  96:Core/Src/adc_joystick.c ****  * Inicia la secuencia de dos conversiones. Se invoca desde la ISR de TIM4,
  97:Core/Src/adc_joystick.c ****  * por lo que debe retornar de inmediato.
  98:Core/Src/adc_joystick.c ****  */
  99:Core/Src/adc_joystick.c **** void adc_joystick_start(void)
 100:Core/Src/adc_joystick.c **** {
 101:Core/Src/adc_joystick.c ****     s_channel = 0;              /* la secuencia empieza siempre por VRX */
 102:Core/Src/adc_joystick.c ****     adc_select_channel(0);
 103:Core/Src/adc_joystick.c ****     HAL_ADC_Start_IT(&hadc1);   /* arranca la conversion con interrupcion EOC */
 104:Core/Src/adc_joystick.c **** }
 105:Core/Src/adc_joystick.c **** 
 106:Core/Src/adc_joystick.c **** /*
 107:Core/Src/adc_joystick.c ****  * HAL_ADC_ConvCpltCallback
 108:Core/Src/adc_joystick.c ****  * La HAL la invoca desde HAL_ADC_IRQHandler al activarse la bandera EOC.
 109:Core/Src/adc_joystick.c ****  * Encadena la segunda conversion sin bloquear el nucleo.
 110:Core/Src/adc_joystick.c ****  */
 111:Core/Src/adc_joystick.c **** void HAL_ADC_ConvCpltCallback(ADC_HandleTypeDef *hadc)
 112:Core/Src/adc_joystick.c **** {
 113:Core/Src/adc_joystick.c ****     if (hadc->Instance != ADC1) {
 114:Core/Src/adc_joystick.c ****         return;   /* proteccion por si se anadiese otro ADC al proyecto */
 115:Core/Src/adc_joystick.c ****     }
 116:Core/Src/adc_joystick.c **** 
 117:Core/Src/adc_joystick.c ****     if (s_channel == 0) {
 118:Core/Src/adc_joystick.c ****         s_raw_x   = (uint16_t)HAL_ADC_GetValue(hadc); /* lee y limpia EOC */
 119:Core/Src/adc_joystick.c ****         s_channel = 1;
 120:Core/Src/adc_joystick.c ****         adc_select_channel(1);        /* conmuta a VRY */
 121:Core/Src/adc_joystick.c ****         HAL_ADC_Start_IT(hadc);       /* segunda conversion */
 122:Core/Src/adc_joystick.c ****     } else {
 123:Core/Src/adc_joystick.c ****         s_raw_y   = (uint16_t)HAL_ADC_GetValue(hadc);
 124:Core/Src/adc_joystick.c ****         s_channel = 0;                /* secuencia completa */
 125:Core/Src/adc_joystick.c ****     }
 126:Core/Src/adc_joystick.c **** }
 127:Core/Src/adc_joystick.c **** 
 128:Core/Src/adc_joystick.c **** /* Accesores de las ultimas muestras crudas */
 129:Core/Src/adc_joystick.c **** uint16_t adc_joystick_raw_x(void) { return s_raw_x; }
 130:Core/Src/adc_joystick.c **** uint16_t adc_joystick_raw_y(void) { return s_raw_y; }
 131:Core/Src/adc_joystick.c **** 
