   1:Core/Src/rtc.c **** /*
   2:Core/Src/rtc.c ****  * rtc.c
   3:Core/Src/rtc.c ****  * Configuracion del RTC con cristal LSE de 32.768 kHz y despertador de 1 s.
   4:Core/Src/rtc.c ****  *
   5:Core/Src/rtc.c ****  * Cadena de division del RTC:
   6:Core/Src/rtc.c ****  *   f_ck_spre = LSE / ((AsynchPrediv + 1) * (SynchPrediv + 1))
   7:Core/Src/rtc.c ****  *             = 32768 / (128 * 256) = 1 Hz
   8:Core/Src/rtc.c ****  *
   9:Core/Src/rtc.c ****  * Se prefiere un preescalado asincrono grande (127) porque esa rama es la que
  10:Core/Src/rtc.c ****  * mas contribuye al ahorro de consumo del contador.
  11:Core/Src/rtc.c ****  */
  12:Core/Src/rtc.c **** #include "rtc.h"
  13:Core/Src/rtc.c **** #include "system_clock.h"
  14:Core/Src/rtc.c **** #include "uart.h"
