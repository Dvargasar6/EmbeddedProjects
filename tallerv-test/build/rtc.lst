  17:Core/Src/rtc.c **** 
  18:Core/Src/rtc.c **** /* Bandera puesta a 1 por la interrupcion de despertador cada segundo.
  19:Core/Src/rtc.c ****    La consume la maquina de estados para refrescar la linea 1 del LCD. */
  20:Core/Src/rtc.c **** volatile uint8_t g_rtc_second_flag = 0;
  21:Core/Src/rtc.c **** 
  22:Core/Src/rtc.c **** /* ------------------------------------------------------------------------
  23:Core/Src/rtc.c ****  * Conversion de las macros __DATE__ y __TIME__ del compilador.
  24:Core/Src/rtc.c ****  * Permite que, la primera vez que se programa la placa, el RTC arranque con
  25:Core/Src/rtc.c ****  * la fecha y hora reales del momento de compilacion en lugar de un valor fijo.
  26:Core/Src/rtc.c ****  * __DATE__ tiene el formato "Jul 21 2026"; __TIME__ el formato "14:35:07".
  27:Core/Src/rtc.c ****  * ---------------------------------------------------------------------- */
