  28              	.LFB268:
   1:Core/Src/stm32f4xx_it.c **** /*
   2:Core/Src/stm32f4xx_it.c ****  * stm32f4xx_it.c
   3:Core/Src/stm32f4xx_it.c ****  * Rutinas de servicio de interrupcion del proyecto.
   4:Core/Src/stm32f4xx_it.c ****  *
   5:Core/Src/stm32f4xx_it.c ****  * Todos los perifericos salvo el I2C trabajan por interrupcion, tal como
   6:Core/Src/stm32f4xx_it.c ****  * exige el enunciado. Cada ISR se limita a delegar en el manejador generico
   7:Core/Src/stm32f4xx_it.c ****  * de la HAL, que a su vez invoca el callback correspondiente en el modulo
   8:Core/Src/stm32f4xx_it.c ****  * del periferico. Ninguna ISR contiene logica de aplicacion.
   9:Core/Src/stm32f4xx_it.c ****  *
  10:Core/Src/stm32f4xx_it.c ****  * Mapa de interrupciones y prioridades (0 = mas urgente):
  11:Core/Src/stm32f4xx_it.c ****  *   USART2_IRQn    prioridad 5   recepcion y transmision serie
  12:Core/Src/stm32f4xx_it.c ****  *   ADC_IRQn       prioridad 6   fin de conversion de cada eje
  13:Core/Src/stm32f4xx_it.c ****  *   TIM3_IRQn      prioridad 7   base de 250 ms para el LED
  14:Core/Src/stm32f4xx_it.c ****  *   TIM4_IRQn      prioridad 7   base de 100 ms del sistema
  15:Core/Src/stm32f4xx_it.c ****  *   EXTI9_5_IRQn   prioridad 8   pulsador SW del joystick (PB5)
  16:Core/Src/stm32f4xx_it.c ****  *   RTC_WKUP_IRQn  prioridad 9   despertador de 1 s del RTC
  17:Core/Src/stm32f4xx_it.c ****  *   SysTick        prioridad 15  contador de milisegundos de la HAL
  18:Core/Src/stm32f4xx_it.c ****  */
  19:Core/Src/stm32f4xx_it.c **** #include "main.h"
  20:Core/Src/stm32f4xx_it.c **** #include "stm32f4xx_it.h"
  21:Core/Src/stm32f4xx_it.c **** #include "timer.h"
  22:Core/Src/stm32f4xx_it.c **** #include "uart.h"
  23:Core/Src/stm32f4xx_it.c **** #include "adc_joystick.h"
  24:Core/Src/stm32f4xx_it.c **** #include "rtc.h"
  25:Core/Src/stm32f4xx_it.c **** #include "gpio.h"
  26:Core/Src/stm32f4xx_it.c **** #include "fsm.h"
  27:Core/Src/stm32f4xx_it.c **** 
  28:Core/Src/stm32f4xx_it.c **** /* ================= Excepciones del nucleo Cortex-M4 ==================== */
