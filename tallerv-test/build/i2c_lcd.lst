  68:Core/Src/i2c_lcd.c **** 
  69:Core/Src/i2c_lcd.c **** /*
  70:Core/Src/i2c_lcd.c ****  * lcd_tx
  71:Core/Src/i2c_lcd.c ****  * Envia n bytes al PCF8574 en una sola transaccion. Devuelve 1 si tuvo exito.
  72:Core/Src/i2c_lcd.c ****  * Contabiliza los fallos para poder diagnosticarlos desde la consola.
  73:Core/Src/i2c_lcd.c ****  */
  74:Core/Src/i2c_lcd.c **** static uint8_t lcd_tx(uint8_t *data, uint16_t n)
  75:Core/Src/i2c_lcd.c **** {
  76:Core/Src/i2c_lcd.c ****     HAL_StatusTypeDef st;
  77:Core/Src/i2c_lcd.c **** 
  78:Core/Src/i2c_lcd.c ****     /* La HAL espera la direccion de 8 bits: el bit 0 queda reservado al
  79:Core/Src/i2c_lcd.c ****        sentido de la transferencia, de ahi el desplazamiento a la izquierda.
  80:Core/Src/i2c_lcd.c ****        Pasar 0x27 en lugar de 0x4E es el error mas frecuente al portar codigo
  81:Core/Src/i2c_lcd.c ****        de Arduino, donde la libreria Wire espera los 7 bits sin desplazar. */
  82:Core/Src/i2c_lcd.c ****     st = HAL_I2C_Master_Transmit(&hi2c1, (uint16_t)(s_addr7 << 1), data, n, 50U);
  83:Core/Src/i2c_lcd.c **** 
  84:Core/Src/i2c_lcd.c ****     if (st != HAL_OK) {
  85:Core/Src/i2c_lcd.c ****         s_errors++;
  86:Core/Src/i2c_lcd.c ****         return 0U;
  87:Core/Src/i2c_lcd.c ****     }
  88:Core/Src/i2c_lcd.c ****     return 1U;
  89:Core/Src/i2c_lcd.c **** }
  90:Core/Src/i2c_lcd.c **** 
  91:Core/Src/i2c_lcd.c **** /*
  92:Core/Src/i2c_lcd.c ****  * lcd_send
  93:Core/Src/i2c_lcd.c ****  * Envia un byte completo al controlador en dos nibbles, con los cuatro
  94:Core/Src/i2c_lcd.c ****  * estados de la linea EN agrupados en una unica transaccion I2C.
  95:Core/Src/i2c_lcd.c ****  * mode = 0x00 -> comando (RS = 0);  mode = 0x01 -> dato (RS = 1).
  96:Core/Src/i2c_lcd.c ****  */
  97:Core/Src/i2c_lcd.c **** static void lcd_send(uint8_t value, uint8_t mode)
  98:Core/Src/i2c_lcd.c **** {
  99:Core/Src/i2c_lcd.c ****     uint8_t hi = (uint8_t)((value & 0xF0U)        | mode | s_backlight);
 100:Core/Src/i2c_lcd.c ****     uint8_t lo = (uint8_t)(((value << 4) & 0xF0U) | mode | s_backlight);
ARM GAS  /tmp/ccvJGlBQ.s 			page 5


 101:Core/Src/i2c_lcd.c **** 
 102:Core/Src/i2c_lcd.c ****     uint8_t seq[4];
 103:Core/Src/i2c_lcd.c ****     seq[0] = (uint8_t)(hi | 0x04U);   /* nibble alto, EN = 1 */
 104:Core/Src/i2c_lcd.c ****     seq[1] = (uint8_t)(hi & ~0x04U);  /* nibble alto, EN = 0 -> captura */
 105:Core/Src/i2c_lcd.c ****     seq[2] = (uint8_t)(lo | 0x04U);   /* nibble bajo, EN = 1 */
 106:Core/Src/i2c_lcd.c ****     seq[3] = (uint8_t)(lo & ~0x04U);  /* nibble bajo, EN = 0 -> captura */
 107:Core/Src/i2c_lcd.c **** 
 108:Core/Src/i2c_lcd.c ****     lcd_tx(seq, 4U);
 109:Core/Src/i2c_lcd.c **** 
 110:Core/Src/i2c_lcd.c ****     /* El HD44780 necesita 37 us para ejecutar la mayoria de instrucciones.
 111:Core/Src/i2c_lcd.c ****        Los comandos lentos (borrado, retorno a origen) anaden su propia espera. */
 112:Core/Src/i2c_lcd.c ****     delay_us(50U);
 113:Core/Src/i2c_lcd.c **** }
 114:Core/Src/i2c_lcd.c **** 
 115:Core/Src/i2c_lcd.c **** /*
 116:Core/Src/i2c_lcd.c ****  * lcd_pulse_nibble
 117:Core/Src/i2c_lcd.c ****  * Variante para la secuencia de arranque, donde solo se envia el nibble alto
 118:Core/Src/i2c_lcd.c ****  * porque el controlador aun no esta en modo de 4 bits.
 119:Core/Src/i2c_lcd.c ****  */
 120:Core/Src/i2c_lcd.c **** static void lcd_pulse_nibble(uint8_t nibble)
 121:Core/Src/i2c_lcd.c **** {
 122:Core/Src/i2c_lcd.c ****     uint8_t seq[2];
 123:Core/Src/i2c_lcd.c ****     seq[0] = (uint8_t)(nibble | 0x04U);
 124:Core/Src/i2c_lcd.c ****     seq[1] = (uint8_t)(nibble & ~0x04U);
 125:Core/Src/i2c_lcd.c **** 
 126:Core/Src/i2c_lcd.c ****     lcd_tx(seq, 2U);
 127:Core/Src/i2c_lcd.c ****     delay_us(50U);
 128:Core/Src/i2c_lcd.c **** }
 129:Core/Src/i2c_lcd.c **** 
 130:Core/Src/i2c_lcd.c **** static void lcd_command(uint8_t c) { lcd_send(c, 0x00U); }
 131:Core/Src/i2c_lcd.c **** static void lcd_data(uint8_t c)    { lcd_send(c, 0x01U); }
