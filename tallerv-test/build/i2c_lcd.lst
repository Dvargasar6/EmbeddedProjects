   1:Core/Src/i2c_lcd.c **** /*
   2:Core/Src/i2c_lcd.c ****  * i2c_lcd.c
   3:Core/Src/i2c_lcd.c ****  * Controlador de LCD HD44780 de 20x4 conectado por I2C mediante un PCF8574.
   4:Core/Src/i2c_lcd.c ****  *
   5:Core/Src/i2c_lcd.c ****  * El HD44780 se opera en modo de 4 bits: cada byte se envia en dos mitades
   6:Core/Src/i2c_lcd.c ****  * (nibbles), primero la alta y despues la baja. Cada nibble se valida con un
   7:Core/Src/i2c_lcd.c ****  * pulso descendente en la linea EN.
   8:Core/Src/i2c_lcd.c ****  *
   9:Core/Src/i2c_lcd.c ****  * Optimizacion importante frente a la implementacion ingenua: los cuatro
  10:Core/Src/i2c_lcd.c ****  * estados que componen un caracter (nibble alto con EN=1, con EN=0, nibble
  11:Core/Src/i2c_lcd.c ****  * bajo con EN=1, con EN=0) se envian en UNA sola transaccion I2C de cuatro
  12:Core/Src/i2c_lcd.c ****  * bytes. El PCF8574 acepta escrituras consecutivas y actualiza sus salidas
  13:Core/Src/i2c_lcd.c ****  * con cada byte recibido, de modo que el propio reloj del bus proporciona la
  14:Core/Src/i2c_lcd.c ****  * separacion temporal entre flancos. Esto reduce el tiempo de escritura de
  15:Core/Src/i2c_lcd.c ****  * una linea de unos 64 ms a unos 7 ms.
  16:Core/Src/i2c_lcd.c ****  */
  17:Core/Src/i2c_lcd.c **** #include "i2c_lcd.h"
  18:Core/Src/i2c_lcd.c **** #include "uart.h"
  19:Core/Src/i2c_lcd.c **** 
  20:Core/Src/i2c_lcd.c **** I2C_HandleTypeDef hi2c1;
  21:Core/Src/i2c_lcd.c **** 
  22:Core/Src/i2c_lcd.c **** /* Direccion de 7 bits del expansor detectada durante la inicializacion */
  23:Core/Src/i2c_lcd.c **** static uint8_t  s_addr7   = 0x27U;
  24:Core/Src/i2c_lcd.c **** 
  25:Core/Src/i2c_lcd.c **** /* 1 si algun dispositivo respondio en el bus */
  26:Core/Src/i2c_lcd.c **** static uint8_t  s_present = 0;
  27:Core/Src/i2c_lcd.c **** 
  28:Core/Src/i2c_lcd.c **** /* Numero de transacciones I2C que devolvieron error */
  29:Core/Src/i2c_lcd.c **** static uint32_t s_errors  = 0;
  30:Core/Src/i2c_lcd.c **** 
  31:Core/Src/i2c_lcd.c **** /* Estado de la retroiluminacion: se mezcla con cada byte enviado */
ARM GAS  /tmp/ccvJGlBQ.s 			page 2


  32:Core/Src/i2c_lcd.c **** static uint8_t  s_backlight = 0x08U;   /* bit P3 a 1 = luz encendida */
  33:Core/Src/i2c_lcd.c **** 
  34:Core/Src/i2c_lcd.c **** /* Direcciones de memoria DDRAM donde empieza cada fila.
  35:Core/Src/i2c_lcd.c ****    En los modulos de 4 filas y 16 columnas las lineas no son contiguas:
  36:Core/Src/i2c_lcd.c ****    la fila 3 continua a la fila 1 y la fila 4 continua a la fila 2. */
  37:Core/Src/i2c_lcd.c **** static const uint8_t s_row_offset[LCD_ROWS] = { 0x00U, 0x40U, 0x14U, 0x54U };
  38:Core/Src/i2c_lcd.c **** 
  39:Core/Src/i2c_lcd.c **** /* ---------------------------------------------------------------------------
  40:Core/Src/i2c_lcd.c ****  * Retardo de microsegundos basado en el contador de ciclos del nucleo (DWT).
  41:Core/Src/i2c_lcd.c ****  * HAL_Delay solo ofrece resolucion de milisegundo, que aqui es tres ordenes de
  42:Core/Src/i2c_lcd.c ****  * magnitud mas de lo necesario y hace el refresco inaceptablemente lento.
  43:Core/Src/i2c_lcd.c ****  * El DWT existe en todos los Cortex-M3/M4/M7 y funciona sin depurador
  44:Core/Src/i2c_lcd.c ****  * conectado, siempre que se habilite TRCENA.
  45:Core/Src/i2c_lcd.c ****  * ------------------------------------------------------------------------- */
