   1:Core/Src/uart.c **** /*
   2:Core/Src/uart.c ****  * uart.c
   3:Core/Src/uart.c ****  * Comunicacion serie por interrupciones y traduccion de comandos a eventos.
   4:Core/Src/uart.c ****  *
   5:Core/Src/uart.c ****  * Comandos aceptados (un solo caracter, sin necesidad de pulsar Enter):
   6:Core/Src/uart.c ****  *   c   pone ambas coordenadas a cero
   7:Core/Src/uart.c ****  *   x   activa el modo X
   8:Core/Src/uart.c ****  *   y   activa el modo Y
   9:Core/Src/uart.c ****  *   +   incrementa la coordenada del modo activo
  10:Core/Src/uart.c ****  *   -   decrementa la coordenada del modo activo
  11:Core/Src/uart.c ****  *   h   enruta el HSI a la salida MCO1 (PA8)
  12:Core/Src/uart.c ****  *   l   enruta el LSE a la salida MCO1
  13:Core/Src/uart.c ****  *   p   enruta el PLL a la salida MCO1
  14:Core/Src/uart.c ****  *   d   informe de diagnostico de los perifericos
  15:Core/Src/uart.c ****  *   s   sondeo completo del bus I2C
  16:Core/Src/uart.c ****  *   ?   imprime la ayuda
  17:Core/Src/uart.c ****  */
  18:Core/Src/uart.c **** #include "uart.h"
  19:Core/Src/uart.c **** #include "fsm.h"
