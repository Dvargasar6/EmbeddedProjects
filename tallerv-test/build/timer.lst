   1:Core/Src/timer.c **** /*
   2:Core/Src/timer.c ****  * timer.c
   3:Core/Src/timer.c ****  * Configuracion de TIM3 (LED a 250 ms) y TIM4 (base de tiempo de 100 ms).
   4:Core/Src/timer.c ****  *
   5:Core/Src/timer.c ****  * Calculo de la temporizacion:
   6:Core/Src/timer.c ****  *
   7:Core/Src/timer.c ****  *   f_TIM = f_APB1 * 2 = 50 MHz * 2 = 100 MHz
   8:Core/Src/timer.c ****  *   f_cnt = f_TIM / (PSC + 1)
   9:Core/Src/timer.c ****  *   T     = (ARR + 1) / f_cnt
  10:Core/Src/timer.c ****  *
  11:Core/Src/timer.c ****  * TIM3: PSC = 9999  -> f_cnt = 100 MHz / 10000 = 10 kHz (paso de 100 us)
  12:Core/Src/timer.c ****  *       ARR = 2499  -> T = 2500 / 10 kHz = 250 ms
  13:Core/Src/timer.c ****  *
  14:Core/Src/timer.c ****  * TIM4: PSC = 9999  -> f_cnt = 10 kHz
  15:Core/Src/timer.c ****  *       ARR = 999   -> T = 1000 / 10 kHz = 100 ms
  16:Core/Src/timer.c ****  *
  17:Core/Src/timer.c ****  * Se eligen PSC y ARR de forma que ARR quede lo mas grande posible dentro de
  18:Core/Src/timer.c ****  * los 16 bits: cuanto mayor es ARR, mejor es la resolucion del periodo.
  19:Core/Src/timer.c ****  */
  20:Core/Src/timer.c **** #include "timer.h"
  21:Core/Src/timer.c **** #include "gpio.h"
  22:Core/Src/timer.c **** #include "adc_joystick.h"
  23:Core/Src/timer.c **** #include "fsm.h"
  24:Core/Src/timer.c **** 
