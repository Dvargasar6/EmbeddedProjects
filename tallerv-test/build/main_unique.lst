1619:Core/Src/main_unique.c ****     snprintf(buf, sizeof(buf), "Y:%+04d ADC:%04u",
1620:Core/Src/main_unique.c ****              (int)s_coord_y, (unsigned)adc_joystick_raw_y());
1621:Core/Src/main_unique.c ****     lcd_update(3U, buf);
1622:Core/Src/main_unique.c **** }
