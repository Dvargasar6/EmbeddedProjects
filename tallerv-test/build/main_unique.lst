1525:Core/Src/main_unique.c **** /*
1526:Core/Src/main_unique.c ****  * lcd_update
1527:Core/Src/main_unique.c ****  * Escribe una fila solo si su contenido difiere del ultimo enviado.
1528:Core/Src/main_unique.c ****  */
1529:Core/Src/main_unique.c **** static void lcd_update(uint8_t row, const char *txt)
1530:Core/Src/main_unique.c **** {
1531:Core/Src/main_unique.c ****     char norm[LCD_COLS + 1U];
1532:Core/Src/main_unique.c ****     uint8_t i, end = 0U;
1533:Core/Src/main_unique.c **** 
1534:Core/Src/main_unique.c ****     /* Normaliza a la anchura exacta de la pantalla para que la comparacion
1535:Core/Src/main_unique.c ****        sea fiable */
1536:Core/Src/main_unique.c ****     for (i = 0U; i < LCD_COLS; i++) {
1537:Core/Src/main_unique.c ****         if (!end && (txt[i] == '\0')) end = 1U;
1538:Core/Src/main_unique.c ****         norm[i] = end ? ' ' : txt[i];
1539:Core/Src/main_unique.c ****     }
1540:Core/Src/main_unique.c ****     norm[LCD_COLS] = '\0';
1541:Core/Src/main_unique.c **** 
1542:Core/Src/main_unique.c ****     if (strncmp(norm, s_shadow[row], LCD_COLS) == 0) {
1543:Core/Src/main_unique.c ****         return;                       /* sin cambios: no se toca el bus */
1544:Core/Src/main_unique.c ****     }
1545:Core/Src/main_unique.c ****     memcpy(s_shadow[row], norm, LCD_COLS + 1U);
1546:Core/Src/main_unique.c ****     lcd_print_line(row, norm);
1547:Core/Src/main_unique.c **** }
