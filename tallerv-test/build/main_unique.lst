 358:Drivers/CMSIS/Include/cmsis_gcc.h ****     }
 359:Drivers/CMSIS/Include/cmsis_gcc.h ****     else if (val < min)
 360:Drivers/CMSIS/Include/cmsis_gcc.h ****     {
