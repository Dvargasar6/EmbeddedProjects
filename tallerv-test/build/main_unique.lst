1216:Core/Src/main_unique.c ****         for (a = 0x38U; a <= 0x3FU; a++) {
1217:Core/Src/main_unique.c ****             if (HAL_I2C_IsDeviceReady(&hi2c1, (uint16_t)(a << 1), 2U, 10U) == HAL_OK) {
1218:Core/Src/main_unique.c ****                 s_addr7 = a; s_present = 1U; break;
1219:Core/Src/main_unique.c ****             }
1220:Core/Src/main_unique.c ****         }
1221:Core/Src/main_unique.c ****     }
1222:Core/Src/main_unique.c **** 
