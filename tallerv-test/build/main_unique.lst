 570:Core/Src/main_unique.c **** /*
 571:Core/Src/main_unique.c ****  * uart_send
 572:Core/Src/main_unique.c ****  * Copia la cadena al buffer circular y activa la transmision si estaba parada.
 573:Core/Src/main_unique.c ****  * No bloquea: si el buffer se llena, los caracteres sobrantes se descartan.
 574:Core/Src/main_unique.c ****  */
 575:Core/Src/main_unique.c **** void uart_send(const char *s)
 576:Core/Src/main_unique.c **** {
 577:Core/Src/main_unique.c ****     uint16_t next;
 578:Core/Src/main_unique.c **** 
 579:Core/Src/main_unique.c ****     while (*s != '\0') {
 580:Core/Src/main_unique.c ****         next = (uint16_t)((s_tx_head + 1U) % UART_TX_BUF_SIZE);
 581:Core/Src/main_unique.c ****         if (next == s_tx_tail) {
 582:Core/Src/main_unique.c ****             break;   /* buffer lleno: se descarta el resto */
 583:Core/Src/main_unique.c ****         }
 584:Core/Src/main_unique.c ****         s_tx_buf[s_tx_head] = (uint8_t)*s++;
 585:Core/Src/main_unique.c ****         s_tx_head = next;
 586:Core/Src/main_unique.c ****     }
 587:Core/Src/main_unique.c ****     uart_start_tx();
 588:Core/Src/main_unique.c **** }
 589:Core/Src/main_unique.c **** 
 590:Core/Src/main_unique.c **** void uart_send_line(const char *s)
 591:Core/Src/main_unique.c **** {
 592:Core/Src/main_unique.c ****     uart_send(s);
 593:Core/Src/main_unique.c ****     uart_send("\r\n");
 594:Core/Src/main_unique.c **** }
