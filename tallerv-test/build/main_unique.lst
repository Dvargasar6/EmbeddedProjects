1273:Core/Src/main_unique.c **** }
1274:Core/Src/main_unique.c **** 
1275:Core/Src/main_unique.c **** void lcd_print(const char *s)
1276:Core/Src/main_unique.c **** {
1277:Core/Src/main_unique.c ****     if (!s_present) return;
1278:Core/Src/main_unique.c ****     while (*s != '\0') {
1279:Core/Src/main_unique.c ****         lcd_data((uint8_t)*s++);
1280:Core/Src/main_unique.c ****     }
1281:Core/Src/main_unique.c **** }
1282:Core/Src/main_unique.c **** 
1283:Core/Src/main_unique.c **** /*
1284:Core/Src/main_unique.c ****  * lcd_print_line
1285:Core/Src/main_unique.c ****  * Escribe una linea completa rellenando con espacios hasta el final, de forma
1286:Core/Src/main_unique.c ****  * que no queden restos del texto anterior. Evita tener que borrar la pantalla
1287:Core/Src/main_unique.c ****  * entera, operacion lenta que produce parpadeo visible.
1288:Core/Src/main_unique.c ****  */
1289:Core/Src/main_unique.c **** void lcd_print_line(uint8_t row, const char *s)
1290:Core/Src/main_unique.c **** {
1291:Core/Src/main_unique.c ****     uint8_t i;
1292:Core/Src/main_unique.c ****     uint8_t end = 0U;   /* 1 cuando ya se alcanzo el fin de la cadena */
1293:Core/Src/main_unique.c **** 
1294:Core/Src/main_unique.c ****     if (!s_present) return;
1295:Core/Src/main_unique.c **** 
1296:Core/Src/main_unique.c ****     lcd_set_cursor(row, 0U);
1297:Core/Src/main_unique.c **** 
1298:Core/Src/main_unique.c ****     for (i = 0U; i < LCD_COLS; i++) {
1299:Core/Src/main_unique.c ****         if (!end && (s[i] == '\0')) {
1300:Core/Src/main_unique.c ****             end = 1U;
1301:Core/Src/main_unique.c ****         }
1302:Core/Src/main_unique.c ****         lcd_data((uint8_t)(end ? ' ' : s[i]));
1303:Core/Src/main_unique.c ****     }
1304:Core/Src/main_unique.c **** }
