 803:Core/Src/main_unique.c **** /* ==========================================================================
 804:Core/Src/main_unique.c ****  * 9. MODULO rtc
 805:Core/Src/main_unique.c ****  *    RTC interno alimentado por el LSE, con despertador de 1 s.
 806:Core/Src/main_unique.c ****  *
 807:Core/Src/main_unique.c ****  *    Cadena de division del RTC:
 808:Core/Src/main_unique.c ****  *      f_ck_spre = LSE / ((AsynchPrediv + 1) * (SynchPrediv + 1))
 809:Core/Src/main_unique.c ****  *                = 32768 / (128 * 256) = 1 Hz
 810:Core/Src/main_unique.c ****  *
 811:Core/Src/main_unique.c ****  *    El RTC reside en el dominio de respaldo, alimentado desde VBAT cuando
 812:Core/Src/main_unique.c ****  *    desaparece VDD: con pila, la cuenta sobrevive al corte de alimentacion.
 813:Core/Src/main_unique.c ****  *    Se usa RTC_BKP_DR0 como testigo para no reinicializar la hora en cada
 814:Core/Src/main_unique.c ****  *    arranque.
 815:Core/Src/main_unique.c ****  * ========================================================================== */
 816:Core/Src/main_unique.c **** 
 817:Core/Src/main_unique.c **** /* Bandera puesta a 1 por la interrupcion de despertador cada segundo.
 818:Core/Src/main_unique.c ****    La consume la maquina de estados para refrescar la linea 1 del LCD. */
 819:Core/Src/main_unique.c **** volatile uint8_t g_rtc_second_flag = 0;
