2046:Core/Src/main_unique.c **** /* ==========================================================================
2047:Core/Src/main_unique.c ****  * 14. Rutinas de servicio de interrupcion
2048:Core/Src/main_unique.c ****  *
ARM GAS  /tmp/ccjBgtoi.s 			page 129


2049:Core/Src/main_unique.c ****  *     Todos los perifericos salvo el I2C trabajan por interrupcion, tal como
2050:Core/Src/main_unique.c ****  *     exige el enunciado. Cada ISR se limita a delegar en el manejador
2051:Core/Src/main_unique.c ****  *     generico de la HAL, que a su vez invoca el callback correspondiente.
2052:Core/Src/main_unique.c ****  *     Ninguna ISR contiene logica de aplicacion.
2053:Core/Src/main_unique.c ****  *
2054:Core/Src/main_unique.c ****  *     Mapa de interrupciones y prioridades (0 = mas urgente):
2055:Core/Src/main_unique.c ****  *       USART2_IRQn    prioridad 5   recepcion y transmision serie
2056:Core/Src/main_unique.c ****  *       ADC_IRQn       prioridad 6   fin de conversion de cada eje
2057:Core/Src/main_unique.c ****  *       TIM3_IRQn      prioridad 7   base de 250 ms para el LED
2058:Core/Src/main_unique.c ****  *       TIM4_IRQn      prioridad 7   base de 100 ms del sistema
2059:Core/Src/main_unique.c ****  *       EXTI9_5_IRQn   prioridad 8   pulsador SW del joystick (PB5)
2060:Core/Src/main_unique.c ****  *       RTC_WKUP_IRQn  prioridad 9   despertador de 1 s del RTC
2061:Core/Src/main_unique.c ****  *       SysTick        prioridad 15  contador de milisegundos de la HAL
2062:Core/Src/main_unique.c ****  * ========================================================================== */
2063:Core/Src/main_unique.c **** 
2064:Core/Src/main_unique.c **** /* --- Excepciones del nucleo Cortex-M4 ------------------------------------ */
2065:Core/Src/main_unique.c **** void NMI_Handler(void)        { while (1) { } }  /* no enmascarable        */
