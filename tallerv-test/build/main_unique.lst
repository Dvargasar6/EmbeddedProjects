1372:Core/Src/main_unique.c ****     htim4.Init.ClockDivision     = TIM_CLOCKDIVISION_DIV1;
1373:Core/Src/main_unique.c ****     htim4.Init.AutoReloadPreload = TIM_AUTORELOAD_PRELOAD_DISABLE;
1374:Core/Src/main_unique.c **** 
