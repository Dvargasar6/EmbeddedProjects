1599:Core/Src/main_unique.c **** 
1600:Core/Src/main_unique.c ****     rtc_format_line(buf, sizeof(buf));
1601:Core/Src/main_unique.c ****     lcd_update(0U, buf);
1602:Core/Src/main_unique.c **** }
1603:Core/Src/main_unique.c **** 
1604:Core/Src/main_unique.c **** /*
1605:Core/Src/main_unique.c ****  * render_coords
1606:Core/Src/main_unique.c ****  * Refresca las filas 2 y 3 con la coordenada y la muestra cruda de cada eje.
1607:Core/Src/main_unique.c ****  * Formato: "X:+025 ADC:2048".
1608:Core/Src/main_unique.c ****  */
1609:Core/Src/main_unique.c **** static void render_coords(void)
1610:Core/Src/main_unique.c **** {
1611:Core/Src/main_unique.c ****     /* El buffer se dimensiona con holgura para que el compilador pueda
1612:Core/Src/main_unique.c ****        descartar cualquier posibilidad de truncamiento en snprintf. */
