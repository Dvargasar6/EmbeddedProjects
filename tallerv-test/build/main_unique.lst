1312:Core/Src/main_unique.c ****  * 11. MODULO timer
1313:Core/Src/main_unique.c ****  *     TIM3 (LED a 250 ms) y TIM4 (base de tiempo de 100 ms).
1314:Core/Src/main_unique.c ****  *
ARM GAS  /tmp/ccjBgtoi.s 			page 30


1315:Core/Src/main_unique.c ****  *     Calculo de la temporizacion:
1316:Core/Src/main_unique.c ****  *       f_TIM = f_APB1 * 2 = 50 MHz * 2 = 100 MHz
1317:Core/Src/main_unique.c ****  *       f_cnt = f_TIM / (PSC + 1)
1318:Core/Src/main_unique.c ****  *       T     = (ARR + 1) / f_cnt
1319:Core/Src/main_unique.c ****  *
1320:Core/Src/main_unique.c ****  *     TIM3: PSC = 9999 -> f_cnt = 10 kHz; ARR = 2499 -> T = 250 ms
1321:Core/Src/main_unique.c ****  *     TIM4: PSC = 9999 -> f_cnt = 10 kHz; ARR =  999 -> T = 100 ms
1322:Core/Src/main_unique.c ****  *
1323:Core/Src/main_unique.c ****  *     Se eligen PSC y ARR de forma que ARR quede lo mas grande posible dentro
1324:Core/Src/main_unique.c ****  *     de los 16 bits: cuanto mayor es ARR, mejor la resolucion del periodo.
1325:Core/Src/main_unique.c ****  * ========================================================================== */
1326:Core/Src/main_unique.c **** 
1327:Core/Src/main_unique.c **** void timer_init(void)
1328:Core/Src/main_unique.c **** {
1329:Core/Src/main_unique.c ****     TIM_ClockConfigTypeDef  src = {0};  /* fuente de reloj del contador   */
1330:Core/Src/main_unique.c ****     TIM_MasterConfigTypeDef mst = {0};  /* configuracion maestro/esclavo  */
1331:Core/Src/main_unique.c **** 
1332:Core/Src/main_unique.c ****     /* ================= TIM3: parpadeo del LED cada 250 ms ============== */
1333:Core/Src/main_unique.c ****     __HAL_RCC_TIM3_CLK_ENABLE();         /* reloj del periferico TIM3      */
1334:Core/Src/main_unique.c **** 
1335:Core/Src/main_unique.c ****     htim3.Instance           = TIM3;
1336:Core/Src/main_unique.c ****     htim3.Init.Prescaler     = 10000U - 1U;  /* divide 100 MHz hasta 10 kHz */
1337:Core/Src/main_unique.c ****     htim3.Init.CounterMode   = TIM_COUNTERMODE_UP;  /* cuenta 0 -> ARR.
1338:Core/Src/main_unique.c ****                                         Alternativas: DOWN, CENTERALIGNED1/2/3 */
1339:Core/Src/main_unique.c ****     htim3.Init.Period        = 2500U - 1U;   /* 2500 pasos de 100 us = 250 ms */
1340:Core/Src/main_unique.c ****     htim3.Init.ClockDivision = TIM_CLOCKDIVISION_DIV1;  /* divisor del filtro
1341:Core/Src/main_unique.c ****                                         digital de las entradas, no del contador */
1342:Core/Src/main_unique.c ****     htim3.Init.AutoReloadPreload = TIM_AUTORELOAD_PRELOAD_DISABLE;
1343:Core/Src/main_unique.c ****                                         /* ARR se escribe de inmediato; con
1344:Core/Src/main_unique.c ****                                            PRELOAD_ENABLE se aplicaria en el
1345:Core/Src/main_unique.c ****                                            siguiente evento de actualizacion */
1346:Core/Src/main_unique.c **** 
1347:Core/Src/main_unique.c ****     if (HAL_TIM_Base_Init(&htim3) != HAL_OK) {
1348:Core/Src/main_unique.c ****         Error_Handler();
1349:Core/Src/main_unique.c ****     }
1350:Core/Src/main_unique.c **** 
1351:Core/Src/main_unique.c ****     /* Reloj interno del microcontrolador como fuente del contador.
1352:Core/Src/main_unique.c ****        Alternativas: ETR externo, o el reloj de otro temporizador (ITRx). */
1353:Core/Src/main_unique.c ****     src.ClockSource = TIM_CLOCKSOURCE_INTERNAL;
1354:Core/Src/main_unique.c ****     if (HAL_TIM_ConfigClockSource(&htim3, &src) != HAL_OK) {
1355:Core/Src/main_unique.c ****         Error_Handler();
1356:Core/Src/main_unique.c ****     }
1357:Core/Src/main_unique.c **** 
1358:Core/Src/main_unique.c ****     /* TIM3 no dispara a ningun otro periferico: TRGO en RESET */
1359:Core/Src/main_unique.c ****     mst.MasterOutputTrigger = TIM_TRGO_RESET;
1360:Core/Src/main_unique.c ****     mst.MasterSlaveMode     = TIM_MASTERSLAVEMODE_DISABLE;
1361:Core/Src/main_unique.c ****     if (HAL_TIMEx_MasterConfigSynchronization(&htim3, &mst) != HAL_OK) {
1362:Core/Src/main_unique.c ****         Error_Handler();
1363:Core/Src/main_unique.c ****     }
1364:Core/Src/main_unique.c **** 
1365:Core/Src/main_unique.c ****     /* ================= TIM4: base de tiempo de 100 ms ================== */
1366:Core/Src/main_unique.c ****     __HAL_RCC_TIM4_CLK_ENABLE();
1367:Core/Src/main_unique.c **** 
1368:Core/Src/main_unique.c ****     htim4.Instance               = TIM4;
1369:Core/Src/main_unique.c ****     htim4.Init.Prescaler         = 10000U - 1U;   /* 10 kHz            */
1370:Core/Src/main_unique.c ****     htim4.Init.CounterMode       = TIM_COUNTERMODE_UP;
1371:Core/Src/main_unique.c ****     htim4.Init.Period            = 1000U - 1U;    /* 1000 * 100 us = 100 ms */
