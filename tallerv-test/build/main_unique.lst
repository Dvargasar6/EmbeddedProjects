 492:Core/Src/main_unique.c **** /* ==========================================================================
 493:Core/Src/main_unique.c ****  * 7. MODULO uart
 494:Core/Src/main_unique.c ****  *    USART2 a 115200 baudios, totalmente gobernada por interrupciones.
 495:Core/Src/main_unique.c ****  *
 496:Core/Src/main_unique.c ****  *    En la Nucleo-F411RE la USART2 esta cableada al depurador ST-LINK, que la
 497:Core/Src/main_unique.c ****  *    expone en el ordenador como puerto virtual (/dev/ttyACM0 en Linux).
 498:Core/Src/main_unique.c ****  *      PA2 -> USART2_TX     PA3 -> USART2_RX
 499:Core/Src/main_unique.c ****  *
 500:Core/Src/main_unique.c ****  *    Comandos aceptados (un solo caracter, sin pulsar Enter):
 501:Core/Src/main_unique.c ****  *      c  coordenadas a cero     x  modo X          y  modo Y
 502:Core/Src/main_unique.c ****  *      +  incrementa             -  decrementa
 503:Core/Src/main_unique.c ****  *      h  MCO1 = HSI             l  MCO1 = LSE      p  MCO1 = PLL
 504:Core/Src/main_unique.c ****  *      d  diagnostico            s  sondeo I2C      ?  ayuda
 505:Core/Src/main_unique.c ****  * ========================================================================== */
 506:Core/Src/main_unique.c **** 
 507:Core/Src/main_unique.c **** /* Byte donde la HAL deposita cada caracter recibido */
 508:Core/Src/main_unique.c **** static volatile uint8_t  s_rx_byte;
 509:Core/Src/main_unique.c **** 
 510:Core/Src/main_unique.c **** /* --- Buffer circular de transmision -------------------------------------- */
 511:Core/Src/main_unique.c **** static volatile uint8_t  s_tx_buf[UART_TX_BUF_SIZE];
 512:Core/Src/main_unique.c **** static volatile uint16_t s_tx_head = 0;   /* posicion de escritura */
 513:Core/Src/main_unique.c **** static volatile uint16_t s_tx_tail = 0;   /* posicion de lectura   */
 514:Core/Src/main_unique.c **** static volatile uint8_t  s_tx_busy = 0;   /* 1 si hay un envio en curso */
 515:Core/Src/main_unique.c **** 
 516:Core/Src/main_unique.c **** /* Byte que se esta transmitiendo en este momento */
 517:Core/Src/main_unique.c **** static volatile uint8_t  s_tx_current;
 518:Core/Src/main_unique.c **** 
 519:Core/Src/main_unique.c **** /*
 520:Core/Src/main_unique.c ****  * uart_start_tx
 521:Core/Src/main_unique.c ****  * Si el buffer no esta vacio y no hay transmision en curso, extrae un byte
 522:Core/Src/main_unique.c ****  * y lo entrega a la HAL. Se llama tanto desde el hilo principal como desde
 523:Core/Src/main_unique.c ****  * la interrupcion de fin de transmision.
 524:Core/Src/main_unique.c ****  */
 525:Core/Src/main_unique.c **** static void uart_start_tx(void)
 526:Core/Src/main_unique.c **** {
 527:Core/Src/main_unique.c ****     if (s_tx_busy || (s_tx_head == s_tx_tail)) {
 528:Core/Src/main_unique.c ****         return;   /* ya hay un envio activo, o no queda nada por enviar */
 529:Core/Src/main_unique.c ****     }
 530:Core/Src/main_unique.c ****     s_tx_current = s_tx_buf[s_tx_tail];
 531:Core/Src/main_unique.c ****     s_tx_tail    = (uint16_t)((s_tx_tail + 1U) % UART_TX_BUF_SIZE);
 532:Core/Src/main_unique.c ****     s_tx_busy    = 1U;
 533:Core/Src/main_unique.c **** 
 534:Core/Src/main_unique.c ****     HAL_UART_Transmit_IT(&huart2, (uint8_t *)&s_tx_current, 1U);
 535:Core/Src/main_unique.c **** }
