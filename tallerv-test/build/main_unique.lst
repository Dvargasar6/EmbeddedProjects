 762:Core/Src/main_unique.c **** /*
 763:Core/Src/main_unique.c ****  * HAL_ADC_ConvCpltCallback
 764:Core/Src/main_unique.c ****  * La HAL la invoca desde HAL_ADC_IRQHandler al activarse la bandera EOC.
 765:Core/Src/main_unique.c ****  * Encadena la segunda conversion sin bloquear el nucleo.
