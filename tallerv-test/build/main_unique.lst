1656:Core/Src/main_unique.c **** /*
1657:Core/Src/main_unique.c ****  * coord_step
1658:Core/Src/main_unique.c ****  * Aplica un incremento a la coordenada del modo activo. Si no hay modo
1659:Core/Src/main_unique.c ****  * seleccionado emite el aviso exigido por el enunciado.
1660:Core/Src/main_unique.c ****  */
1661:Core/Src/main_unique.c **** static void coord_step(int16_t delta)
1662:Core/Src/main_unique.c **** {
1663:Core/Src/main_unique.c ****     switch (s_state) {
1664:Core/Src/main_unique.c **** 
1665:Core/Src/main_unique.c ****     case ST_MODE_X:
1666:Core/Src/main_unique.c ****         s_coord_x = clamp_coord((int32_t)s_coord_x + delta);
1667:Core/Src/main_unique.c ****         render_coords();
1668:Core/Src/main_unique.c ****         break;
1669:Core/Src/main_unique.c **** 
1670:Core/Src/main_unique.c ****     case ST_MODE_Y:
1671:Core/Src/main_unique.c ****         s_coord_y = clamp_coord((int32_t)s_coord_y + delta);
1672:Core/Src/main_unique.c ****         render_coords();
1673:Core/Src/main_unique.c ****         break;
1674:Core/Src/main_unique.c **** 
1675:Core/Src/main_unique.c ****     case ST_MESSAGE:
1676:Core/Src/main_unique.c ****         /* Si ya se esta mostrando el aviso se prolonga su duracion, salvo que
1677:Core/Src/main_unique.c ****            el modo memorizado sea valido, en cuyo caso se aplica el paso. */
1678:Core/Src/main_unique.c ****         if (s_prev == ST_MODE_X) {
1679:Core/Src/main_unique.c ****             s_coord_x = clamp_coord((int32_t)s_coord_x + delta);
1680:Core/Src/main_unique.c ****             render_coords();
1681:Core/Src/main_unique.c ****         } else if (s_prev == ST_MODE_Y) {
1682:Core/Src/main_unique.c ****             s_coord_y = clamp_coord((int32_t)s_coord_y + delta);
1683:Core/Src/main_unique.c ****             render_coords();
1684:Core/Src/main_unique.c ****         } else {
1685:Core/Src/main_unique.c ****             s_msg_timeout = MSG_DURATION_TICKS;
1686:Core/Src/main_unique.c ****         }
1687:Core/Src/main_unique.c ****         break;
ARM GAS  /tmp/ccjBgtoi.s 			page 60


1688:Core/Src/main_unique.c **** 
1689:Core/Src/main_unique.c ****     default:
1690:Core/Src/main_unique.c ****         show_message(TXT_NO_MODE);
1691:Core/Src/main_unique.c ****         uart_send_line("ERROR: seleccione modo con 'x' o 'y'");
1692:Core/Src/main_unique.c ****         break;
1693:Core/Src/main_unique.c ****     }
1694:Core/Src/main_unique.c **** }
