1559:Core/Src/main_unique.c **** /*
1560:Core/Src/main_unique.c ****  * render_line2
1561:Core/Src/main_unique.c ****  * Compone la ventana visible de la fila 1.
1562:Core/Src/main_unique.c ****  * Si el texto cabe entero se muestra fijo; si no, se desplaza ciclicamente
1563:Core/Src/main_unique.c ****  * anadiendo un separador de tres espacios entre el final y el principio.
1564:Core/Src/main_unique.c ****  */
1565:Core/Src/main_unique.c **** static void render_line2(void)
1566:Core/Src/main_unique.c **** {
1567:Core/Src/main_unique.c ****     char     win[LCD_COLS + 1U];
1568:Core/Src/main_unique.c ****     uint16_t len, total, i, idx;
1569:Core/Src/main_unique.c **** 
1570:Core/Src/main_unique.c ****     if (s_line2 == NULL) {
1571:Core/Src/main_unique.c ****         return;
1572:Core/Src/main_unique.c ****     }
1573:Core/Src/main_unique.c **** 
ARM GAS  /tmp/ccjBgtoi.s 			page 58


1574:Core/Src/main_unique.c ****     len = (uint16_t)strlen(s_line2);
1575:Core/Src/main_unique.c **** 
1576:Core/Src/main_unique.c ****     if (len <= LCD_COLS) {
1577:Core/Src/main_unique.c ****         lcd_update(1U, s_line2);   /* cabe entero: sin desplazamiento */
1578:Core/Src/main_unique.c ****         return;
1579:Core/Src/main_unique.c ****     }
1580:Core/Src/main_unique.c **** 
1581:Core/Src/main_unique.c ****     total = (uint16_t)(len + 3U);      /* longitud del ciclo con separador */
1582:Core/Src/main_unique.c **** 
1583:Core/Src/main_unique.c ****     for (i = 0U; i < LCD_COLS; i++) {
1584:Core/Src/main_unique.c ****         idx = (uint16_t)((s_scroll + i) % total);
1585:Core/Src/main_unique.c ****         win[i] = (idx < len) ? s_line2[idx] : ' ';
1586:Core/Src/main_unique.c ****     }
1587:Core/Src/main_unique.c ****     win[LCD_COLS] = '\0';
1588:Core/Src/main_unique.c **** 
1589:Core/Src/main_unique.c ****     lcd_update(1U, win);
1590:Core/Src/main_unique.c **** }
1591:Core/Src/main_unique.c **** 
1592:Core/Src/main_unique.c **** /*
1593:Core/Src/main_unique.c ****  * render_time
