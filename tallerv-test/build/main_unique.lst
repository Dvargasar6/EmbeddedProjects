1264:Core/Src/main_unique.c **** 
1265:Core/Src/main_unique.c **** void lcd_set_cursor(uint8_t row, uint8_t col)
1266:Core/Src/main_unique.c **** {
1267:Core/Src/main_unique.c ****     if (!s_present) return;
1268:Core/Src/main_unique.c ****     if (row >= LCD_ROWS) row = LCD_ROWS - 1U;
