 750:Core/Src/main_unique.c **** /*
 751:Core/Src/main_unique.c ****  * adc_joystick_start
 752:Core/Src/main_unique.c ****  * Inicia la secuencia de dos conversiones. Se invoca desde la ISR de TIM4,
 753:Core/Src/main_unique.c ****  * por lo que debe retornar de inmediato.
 754:Core/Src/main_unique.c ****  */
 755:Core/Src/main_unique.c **** void adc_joystick_start(void)
 756:Core/Src/main_unique.c **** {
