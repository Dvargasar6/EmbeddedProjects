 351:Core/Src/main_unique.c **** /*
 352:Core/Src/main_unique.c ****  * system_clock_mco_set
 353:Core/Src/main_unique.c ****  * Enruta la fuente indicada al pin PA8 (MCO1) con el mejor prescaler posible.
 354:Core/Src/main_unique.c ****  *
 355:Core/Src/main_unique.c ****  * Criterio de "mejor prescaler": la menor division que mantenga la senal
 356:Core/Src/main_unique.c ****  * medible con un osciloscopio o analizador logico corriente.
 357:Core/Src/main_unique.c ****  *   - HSI 16 MHz     -> /1 = 16 MHz     (sin division, se observa integra)
 358:Core/Src/main_unique.c ****  *   - LSE 32.768 kHz -> /1 = 32.768 kHz (dividirla la haria irreconocible)
 359:Core/Src/main_unique.c ****  *   - PLL 100 MHz    -> /5 = 20 MHz     (/5 es la maxima division disponible;
 360:Core/Src/main_unique.c ****  *                                        reduce el slew rate exigido al pin y
 361:Core/Src/main_unique.c ****  *                                        evita el deterioro del flanco que
 362:Core/Src/main_unique.c ****  *                                        presenta la salida directa a 100 MHz)
 363:Core/Src/main_unique.c ****  *
 364:Core/Src/main_unique.c ****  * HAL_RCC_MCOConfig se encarga internamente de habilitar el reloj de GPIOA y
 365:Core/Src/main_unique.c ****  * de configurar PA8 como funcion alternativa AF0 a muy alta velocidad.
 366:Core/Src/main_unique.c ****  */
 367:Core/Src/main_unique.c **** void system_clock_mco_set(mco_src_t src)
 368:Core/Src/main_unique.c **** {
 369:Core/Src/main_unique.c ****     switch (src) {
 370:Core/Src/main_unique.c **** 
 371:Core/Src/main_unique.c ****     case MCO_SRC_HSI:
