 775:Core/Src/main_unique.c ****         s_channel = 1;
 776:Core/Src/main_unique.c ****         adc_select_channel(1);        /* conmuta a VRY */
 777:Core/Src/main_unique.c ****         HAL_ADC_Start_IT(hadc);       /* segunda conversion */
