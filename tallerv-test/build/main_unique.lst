2212:Core/Src/main_unique.c **** int main(void)
2213:Core/Src/main_unique.c **** {
2214:Core/Src/main_unique.c ****     /* --- Capa de arranque ------------------------------------------------ */
2215:Core/Src/main_unique.c ****     HAL_Init();     /* configura la FLASH, el SysTick a 1 ms y llama a
2216:Core/Src/main_unique.c ****                        HAL_MspInit(). Debe ser la primera llamada. */
2217:Core/Src/main_unique.c **** 
2218:Core/Src/main_unique.c ****     /* Cuatro bits de prioridad de expropiacion y ninguno de subprioridad.
2219:Core/Src/main_unique.c ****        Simplifica el diseno: el numero que se pasa a HAL_NVIC_SetPriority es
2220:Core/Src/main_unique.c ****        directamente la prioridad, entre 0 (maxima) y 15 (minima). */
2221:Core/Src/main_unique.c ****     HAL_NVIC_SetPriorityGrouping(NVIC_PRIORITYGROUP_4);
2222:Core/Src/main_unique.c **** 
2223:Core/Src/main_unique.c ****     system_clock_init();   /* SYSCLK a 100 MHz, LSE en marcha, MCO1 activa */
2224:Core/Src/main_unique.c **** 
2225:Core/Src/main_unique.c ****     /* --- Perifericos ----------------------------------------------------- */
2226:Core/Src/main_unique.c ****     gpio_init();           /* LED en PH1 y pulsador del joystick en PB5     */
2227:Core/Src/main_unique.c ****     uart_init();           /* USART2 a 115200 por interrupciones            */
2228:Core/Src/main_unique.c ****     adc_joystick_init();   /* ADC1 sobre PA0 y PA1 por interrupciones       */
2229:Core/Src/main_unique.c ****     rtc_init();            /* RTC con LSE y despertador de 1 s              */
2230:Core/Src/main_unique.c ****     lcd_init();            /* LCD por I2C1 (unico periferico sondeado)      */
2231:Core/Src/main_unique.c ****     timer_init();          /* TIM3 (LED, 250 ms) y TIM4 (base de 100 ms)    */
2232:Core/Src/main_unique.c **** 
2233:Core/Src/main_unique.c ****     /* --- Aplicacion ------------------------------------------------------ */
2234:Core/Src/main_unique.c ****     fsm_init();            /* estado inicial y pantalla de bienvenida       */
2235:Core/Src/main_unique.c **** 
2236:Core/Src/main_unique.c ****     while (1) {
2237:Core/Src/main_unique.c ****         fsm_run();         /* consume los eventos encolados por las ISR     */
2238:Core/Src/main_unique.c ****     }
2239:Core/Src/main_unique.c **** }
