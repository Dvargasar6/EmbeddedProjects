1696:Core/Src/main_unique.c **** /*
1697:Core/Src/main_unique.c ****  * apply_joystick
1698:Core/Src/main_unique.c ****  * Traduce la posicion del joystick en incrementos de coordenada. Se ejecuta
1699:Core/Src/main_unique.c ****  * cada 100 ms, de modo que mantener la palanca desviada produce un barrido
1700:Core/Src/main_unique.c ****  * continuo de 10 unidades por segundo.
1701:Core/Src/main_unique.c ****  */
1702:Core/Src/main_unique.c **** static void apply_joystick(void)
1703:Core/Src/main_unique.c **** {
1704:Core/Src/main_unique.c ****     int8_t dx = adc_joystick_dir_x();
1705:Core/Src/main_unique.c ****     int8_t dy = adc_joystick_dir_y();
1706:Core/Src/main_unique.c **** 
1707:Core/Src/main_unique.c ****     if (dx != 0) {
1708:Core/Src/main_unique.c ****         s_coord_x = clamp_coord((int32_t)s_coord_x + dx);
1709:Core/Src/main_unique.c ****     }
1710:Core/Src/main_unique.c ****     if (dy != 0) {
1711:Core/Src/main_unique.c ****         s_coord_y = clamp_coord((int32_t)s_coord_y + dy);
1712:Core/Src/main_unique.c ****     }
1713:Core/Src/main_unique.c **** }
