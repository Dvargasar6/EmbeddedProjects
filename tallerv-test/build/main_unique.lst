1073:Core/Src/main_unique.c **** /*
1074:Core/Src/main_unique.c ****  * lcd_tx
1075:Core/Src/main_unique.c ****  * Envia n bytes al PCF8574 en una sola transaccion. Devuelve 1 si tuvo exito.
1076:Core/Src/main_unique.c ****  * Contabiliza los fallos para poder diagnosticarlos desde la consola.
1077:Core/Src/main_unique.c ****  */
1078:Core/Src/main_unique.c **** static uint8_t lcd_tx(uint8_t *data, uint16_t n)
1079:Core/Src/main_unique.c **** {
1080:Core/Src/main_unique.c ****     HAL_StatusTypeDef st;
1081:Core/Src/main_unique.c **** 
1082:Core/Src/main_unique.c ****     /* La HAL espera la direccion de 8 bits: el bit 0 queda reservado al
1083:Core/Src/main_unique.c ****        sentido de la transferencia, de ahi el desplazamiento a la izquierda.
1084:Core/Src/main_unique.c ****        Pasar 0x27 en lugar de 0x4E es el error mas frecuente al portar codigo
1085:Core/Src/main_unique.c ****        de Arduino, donde la libreria Wire espera los 7 bits sin desplazar. */
1086:Core/Src/main_unique.c ****     st = HAL_I2C_Master_Transmit(&hi2c1, (uint16_t)(s_addr7 << 1), data, n, 50U);
ARM GAS  /tmp/ccjBgtoi.s 			page 26


1087:Core/Src/main_unique.c **** 
1088:Core/Src/main_unique.c ****     if (st != HAL_OK) {
1089:Core/Src/main_unique.c ****         s_errors++;
1090:Core/Src/main_unique.c ****         return 0U;
1091:Core/Src/main_unique.c ****     }
1092:Core/Src/main_unique.c ****     return 1U;
1093:Core/Src/main_unique.c **** }
1094:Core/Src/main_unique.c **** 
1095:Core/Src/main_unique.c **** /*
1096:Core/Src/main_unique.c ****  * lcd_send
1097:Core/Src/main_unique.c ****  * Envia un byte completo al controlador en dos nibbles, con los cuatro
1098:Core/Src/main_unique.c ****  * estados de la linea EN agrupados en una unica transaccion I2C.
1099:Core/Src/main_unique.c ****  * mode = 0x00 -> comando (RS = 0);  mode = 0x01 -> dato (RS = 1).
1100:Core/Src/main_unique.c ****  */
1101:Core/Src/main_unique.c **** static void lcd_send(uint8_t value, uint8_t mode)
1102:Core/Src/main_unique.c **** {
1103:Core/Src/main_unique.c ****     uint8_t hi = (uint8_t)((value & 0xF0U)        | mode | s_backlight);
1104:Core/Src/main_unique.c ****     uint8_t lo = (uint8_t)(((value << 4) & 0xF0U) | mode | s_backlight);
1105:Core/Src/main_unique.c **** 
1106:Core/Src/main_unique.c ****     uint8_t seq[4];
1107:Core/Src/main_unique.c ****     seq[0] = (uint8_t)(hi | 0x04U);   /* nibble alto, EN = 1 */
1108:Core/Src/main_unique.c ****     seq[1] = (uint8_t)(hi & ~0x04U);  /* nibble alto, EN = 0 -> captura */
1109:Core/Src/main_unique.c ****     seq[2] = (uint8_t)(lo | 0x04U);   /* nibble bajo, EN = 1 */
1110:Core/Src/main_unique.c ****     seq[3] = (uint8_t)(lo & ~0x04U);  /* nibble bajo, EN = 0 -> captura */
1111:Core/Src/main_unique.c **** 
1112:Core/Src/main_unique.c ****     lcd_tx(seq, 4U);
1113:Core/Src/main_unique.c **** 
1114:Core/Src/main_unique.c ****     /* El HD44780 necesita 37 us para ejecutar la mayoria de instrucciones.
1115:Core/Src/main_unique.c ****        Los comandos lentos (borrado, retorno a origen) anaden su propia espera. */
1116:Core/Src/main_unique.c ****     delay_us(50U);
1117:Core/Src/main_unique.c **** }
1118:Core/Src/main_unique.c **** 
1119:Core/Src/main_unique.c **** /*
1120:Core/Src/main_unique.c ****  * lcd_pulse_nibble
1121:Core/Src/main_unique.c ****  * Variante para la secuencia de arranque, donde solo se envia el nibble alto
1122:Core/Src/main_unique.c ****  * porque el controlador aun no esta en modo de 4 bits.
1123:Core/Src/main_unique.c ****  */
1124:Core/Src/main_unique.c **** static void lcd_pulse_nibble(uint8_t nibble)
1125:Core/Src/main_unique.c **** {
1126:Core/Src/main_unique.c ****     uint8_t seq[2];
1127:Core/Src/main_unique.c ****     seq[0] = (uint8_t)(nibble | 0x04U);
1128:Core/Src/main_unique.c ****     seq[1] = (uint8_t)(nibble & ~0x04U);
1129:Core/Src/main_unique.c **** 
1130:Core/Src/main_unique.c ****     lcd_tx(seq, 2U);
1131:Core/Src/main_unique.c ****     delay_us(50U);
1132:Core/Src/main_unique.c **** }
1133:Core/Src/main_unique.c **** 
1134:Core/Src/main_unique.c **** static void lcd_command(uint8_t c) { lcd_send(c, 0x00U); }
1135:Core/Src/main_unique.c **** static void lcd_data(uint8_t c)    { lcd_send(c, 0x01U); }
