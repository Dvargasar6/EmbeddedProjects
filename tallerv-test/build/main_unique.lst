 661:Core/Src/main_unique.c **** /* ==========================================================================
 662:Core/Src/main_unique.c ****  * 8. MODULO adc_joystick
 663:Core/Src/main_unique.c ****  *    Adquisicion de los dos ejes del joystick con ADC1 en modo interrupcion.
 664:Core/Src/main_unique.c ****  *
 665:Core/Src/main_unique.c ****  *    Estrategia: el ADC del STM32F4 dispone de un unico registro de datos.
 666:Core/Src/main_unique.c ****  *    Para leer dos canales sin DMA se convierte de uno en uno y se conmuta el
 667:Core/Src/main_unique.c ****  *    canal dentro del callback de fin de conversion:
 668:Core/Src/main_unique.c ****  *
 669:Core/Src/main_unique.c ****  *      TIM4 (100 ms) --> adc_joystick_start() --> conversion canal IN0
 670:Core/Src/main_unique.c ****  *             callback --> guarda VRX, selecciona IN1, arranca de nuevo
 671:Core/Src/main_unique.c ****  *             callback --> guarda VRY, secuencia terminada
 672:Core/Src/main_unique.c ****  *
 673:Core/Src/main_unique.c ****  *    Conexionado: VRX -> PA0 (IN0), VRY -> PA1 (IN1), SW -> PB5.
 674:Core/Src/main_unique.c ****  * ========================================================================== */
 675:Core/Src/main_unique.c **** 
 676:Core/Src/main_unique.c **** /* Indice del canal en curso: 0 = VRX (IN0), 1 = VRY (IN1). volatile porque
 677:Core/Src/main_unique.c ****    se modifica dentro de una interrupcion y se lee fuera de ella. */
 678:Core/Src/main_unique.c **** static volatile uint8_t  s_channel = 0;
 679:Core/Src/main_unique.c **** 
 680:Core/Src/main_unique.c **** /* Ultimas muestras validas de cada eje */
 681:Core/Src/main_unique.c **** static volatile uint16_t s_raw_x = JOY_CENTER;
 682:Core/Src/main_unique.c **** static volatile uint16_t s_raw_y = JOY_CENTER;
 683:Core/Src/main_unique.c **** 
 684:Core/Src/main_unique.c **** /*
 685:Core/Src/main_unique.c ****  * adc_select_channel
 686:Core/Src/main_unique.c ****  * Programa el canal que ocupara el primer puesto de la secuencia de conversion.
 687:Core/Src/main_unique.c ****  * Funcion interna (static): no forma parte de la interfaz del modulo.
 688:Core/Src/main_unique.c ****  */
 689:Core/Src/main_unique.c **** static void adc_select_channel(uint8_t idx)
 690:Core/Src/main_unique.c **** {
 691:Core/Src/main_unique.c ****     ADC_ChannelConfTypeDef ch = {0};
 692:Core/Src/main_unique.c **** 
 693:Core/Src/main_unique.c ****     ch.Channel      = (idx == 0) ? ADC_CHANNEL_0 : ADC_CHANNEL_1;
 694:Core/Src/main_unique.c ****     ch.Rank         = 1;   /* primera y unica posicion de la secuencia */
 695:Core/Src/main_unique.c ****     ch.SamplingTime = ADC_SAMPLETIME_84CYCLES;
 696:Core/Src/main_unique.c ****     /* Tiempo de muestreo: 84 ciclos de ADCCLK. Debe ser suficiente para que el
 697:Core/Src/main_unique.c ****        condensador de muestreo se cargue a traves de la impedancia de la fuente.
 698:Core/Src/main_unique.c ****        El potenciometro del joystick ronda los 10 kohm, valor alto, por lo que
 699:Core/Src/main_unique.c ****        se toma un tiempo generoso. Alternativas: 3, 15, 28, 56, 112, 144, 480
 700:Core/Src/main_unique.c ****        ciclos. Un tiempo demasiado corto produce lecturas bajas y ruidosas. */
 701:Core/Src/main_unique.c **** 
 702:Core/Src/main_unique.c ****     if (HAL_ADC_ConfigChannel(&hadc1, &ch) != HAL_OK) {
 703:Core/Src/main_unique.c ****         Error_Handler();
 704:Core/Src/main_unique.c ****     }
 705:Core/Src/main_unique.c **** }
 706:Core/Src/main_unique.c **** 
 707:Core/Src/main_unique.c **** void adc_joystick_init(void)
 708:Core/Src/main_unique.c **** {
 709:Core/Src/main_unique.c ****     __HAL_RCC_ADC1_CLK_ENABLE();   /* reloj del ADC1 (bus APB2) */
 710:Core/Src/main_unique.c **** 
 711:Core/Src/main_unique.c ****     hadc1.Instance = ADC1;
 712:Core/Src/main_unique.c **** 
 713:Core/Src/main_unique.c ****     /* ADCCLK = PCLK2 / 4 = 100 MHz / 4 = 25 MHz.
 714:Core/Src/main_unique.c ****        El maximo admitido por el ADC del F411 es 36 MHz; DIV2 daria 50 MHz y
ARM GAS  /tmp/ccjBgtoi.s 			page 14


 715:Core/Src/main_unique.c ****        violaria la especificacion. Alternativas: DIV2, DIV4, DIV6, DIV8. */
 716:Core/Src/main_unique.c ****     hadc1.Init.ClockPrescaler = ADC_CLOCK_SYNC_PCLK_DIV4;
 717:Core/Src/main_unique.c **** 
 718:Core/Src/main_unique.c ****     hadc1.Init.Resolution = ADC_RESOLUTION_12B;  /* 0..4095. Alternativas:
 719:Core/Src/main_unique.c ****                                         10B, 8B, 6B; menor resolucion implica
 720:Core/Src/main_unique.c ****                                         conversiones mas rapidas */
 721:Core/Src/main_unique.c ****     hadc1.Init.ScanConvMode          = DISABLE;  /* un solo canal por secuencia */
 722:Core/Src/main_unique.c ****     hadc1.Init.ContinuousConvMode    = DISABLE;  /* conversion unica bajo demanda */
 723:Core/Src/main_unique.c ****     hadc1.Init.DiscontinuousConvMode = DISABLE;
 724:Core/Src/main_unique.c ****     hadc1.Init.ExternalTrigConv      = ADC_SOFTWARE_START;
 725:Core/Src/main_unique.c ****                                         /* el disparo lo da el software desde
 726:Core/Src/main_unique.c ****                                            la ISR de TIM4. Alternativa: disparo
 727:Core/Src/main_unique.c ****                                            directo por TRGO de un temporizador */
 728:Core/Src/main_unique.c ****     hadc1.Init.ExternalTrigConvEdge  = ADC_EXTERNALTRIGCONVEDGE_NONE;
 729:Core/Src/main_unique.c ****     hadc1.Init.DataAlign             = ADC_DATAALIGN_RIGHT;
 730:Core/Src/main_unique.c ****                                         /* resultado justificado a la derecha:
 731:Core/Src/main_unique.c ****                                            el valor se lee directamente sin
 732:Core/Src/main_unique.c ****                                            desplazamientos */
 733:Core/Src/main_unique.c ****     hadc1.Init.NbrOfConversion       = 1;
 734:Core/Src/main_unique.c ****     hadc1.Init.DMAContinuousRequests = DISABLE;
 735:Core/Src/main_unique.c ****     hadc1.Init.EOCSelection          = ADC_EOC_SINGLE_CONV;
 736:Core/Src/main_unique.c ****                                         /* la bandera EOC se activa al terminar
 737:Core/Src/main_unique.c ****                                            cada conversion individual */
 738:Core/Src/main_unique.c **** 
 739:Core/Src/main_unique.c ****     if (HAL_ADC_Init(&hadc1) != HAL_OK) {
 740:Core/Src/main_unique.c ****         Error_Handler();
 741:Core/Src/main_unique.c ****     }
 742:Core/Src/main_unique.c **** 
 743:Core/Src/main_unique.c ****     adc_select_channel(0);   /* deja seleccionado VRX para la primera lectura */
 744:Core/Src/main_unique.c **** 
 745:Core/Src/main_unique.c ****     /* Prioridad 6: por debajo de la UART, por encima de los temporizadores */
 746:Core/Src/main_unique.c ****     HAL_NVIC_SetPriority(ADC_IRQn, 6, 0);
 747:Core/Src/main_unique.c ****     HAL_NVIC_EnableIRQ(ADC_IRQn);
 748:Core/Src/main_unique.c **** }
