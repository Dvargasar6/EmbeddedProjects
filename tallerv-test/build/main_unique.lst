1919:Core/Src/main_unique.c **** /* ==========================================================================
1920:Core/Src/main_unique.c ****  * 13. MSP: Microcontroller Support Package
1921:Core/Src/main_unique.c ****  *
1922:Core/Src/main_unique.c ****  *     La HAL separa la configuracion logica de un periferico (registros de
1923:Core/Src/main_unique.c ****  *     modo, velocidad, formato) de su conexion fisica (reloj de bus, pines,
1924:Core/Src/main_unique.c ****  *     NVIC). La primera vive en el modulo del periferico; la segunda se
1925:Core/Src/main_unique.c ****  *     centraliza aqui, porque HAL_<PPP>_Init() invoca automaticamente a
1926:Core/Src/main_unique.c ****  *     HAL_<PPP>_MspInit().
1927:Core/Src/main_unique.c ****  *
1928:Core/Src/main_unique.c ****  *     Mapa de pines completo:
1929:Core/Src/main_unique.c ****  *       PA0  ADC1_IN0    VRX del joystick
1930:Core/Src/main_unique.c ****  *       PA1  ADC1_IN1    VRY del joystick
1931:Core/Src/main_unique.c ****  *       PA2  USART2_TX   consola serie (via ST-LINK)
1932:Core/Src/main_unique.c ****  *       PA3  USART2_RX   consola serie (via ST-LINK)
1933:Core/Src/main_unique.c ****  *       PA8  MCO1        salida de reloj conmutable
1934:Core/Src/main_unique.c ****  *       PB5  EXTI5       pulsador SW del joystick
1935:Core/Src/main_unique.c ****  *       PB8  I2C1_SCL    reloj del bus del LCD
1936:Core/Src/main_unique.c ****  *       PB9  I2C1_SDA    datos del bus del LCD
1937:Core/Src/main_unique.c ****  *       PH1  GPIO out    LED blinky
1938:Core/Src/main_unique.c ****  *       PC14 OSC32_IN    cristal LSE de 32.768 kHz
1939:Core/Src/main_unique.c ****  *       PC15 OSC32_OUT   cristal LSE de 32.768 kHz
1940:Core/Src/main_unique.c ****  * ========================================================================== */
1941:Core/Src/main_unique.c **** 
