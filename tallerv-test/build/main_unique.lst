 610:Core/Src/main_unique.c **** /*
 611:Core/Src/main_unique.c ****  * HAL_UART_RxCpltCallback
 612:Core/Src/main_unique.c ****  * La HAL la invoca al recibir un caracter. Traduce el caracter a un evento
 613:Core/Src/main_unique.c ****  * de la maquina de estados y vuelve a armar la recepcion.
 614:Core/Src/main_unique.c ****  *
 615:Core/Src/main_unique.c ****  * Se aceptan mayusculas y minusculas para mayor comodidad del operador.
 616:Core/Src/main_unique.c ****  */
 617:Core/Src/main_unique.c **** void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart)
 618:Core/Src/main_unique.c **** {
 619:Core/Src/main_unique.c ****     uint8_t c;
 620:Core/Src/main_unique.c **** 
 621:Core/Src/main_unique.c ****     if (huart->Instance != USART2) {
 622:Core/Src/main_unique.c ****         return;
 623:Core/Src/main_unique.c ****     }
 624:Core/Src/main_unique.c **** 
 625:Core/Src/main_unique.c ****     c = s_rx_byte;
 626:Core/Src/main_unique.c **** 
 627:Core/Src/main_unique.c ****     switch (c) {
 628:Core/Src/main_unique.c ****     case 'c': case 'C': fsm_post_event(EV_CMD_CLEAR);   break;
 629:Core/Src/main_unique.c ****     case 'x': case 'X': fsm_post_event(EV_CMD_MODE_X);  break;
 630:Core/Src/main_unique.c ****     case 'y': case 'Y': fsm_post_event(EV_CMD_MODE_Y);  break;
 631:Core/Src/main_unique.c ****     case '+':           fsm_post_event(EV_CMD_INC);     break;
 632:Core/Src/main_unique.c ****     case '-':           fsm_post_event(EV_CMD_DEC);     break;
 633:Core/Src/main_unique.c ****     case 'h': case 'H': fsm_post_event(EV_CMD_MCO_HSI); break;
 634:Core/Src/main_unique.c ****     case 'l': case 'L': fsm_post_event(EV_CMD_MCO_LSE); break;
 635:Core/Src/main_unique.c ****     case 'p': case 'P': fsm_post_event(EV_CMD_MCO_PLL); break;
 636:Core/Src/main_unique.c ****     case 'd': case 'D': fsm_post_event(EV_CMD_DIAG);    break;
 637:Core/Src/main_unique.c ****     case 's': case 'S': fsm_post_event(EV_CMD_SCAN);    break;
 638:Core/Src/main_unique.c ****     case '?':           fsm_post_event(EV_CMD_HELP);    break;
 639:Core/Src/main_unique.c ****     default:            /* cualquier otro caracter se ignora */    break;
 640:Core/Src/main_unique.c ****     }
 641:Core/Src/main_unique.c **** 
 642:Core/Src/main_unique.c ****     /* Rearma la recepcion del siguiente byte. Omitir esta llamada deja la
 643:Core/Src/main_unique.c ****        UART sorda tras el primer caracter: es el error mas frecuente al
 644:Core/Src/main_unique.c ****        trabajar con HAL_UART_Receive_IT. */
 645:Core/Src/main_unique.c ****     HAL_UART_Receive_IT(&huart2, (uint8_t *)&s_rx_byte, 1U);
 646:Core/Src/main_unique.c **** }
