 821:Core/Src/main_unique.c **** /* ------------------------------------------------------------------------
 822:Core/Src/main_unique.c ****  * Conversion de las macros __DATE__ y __TIME__ del compilador.
 823:Core/Src/main_unique.c ****  * Permite que, la primera vez que se programa la placa, el RTC arranque con
 824:Core/Src/main_unique.c ****  * la fecha y hora reales del momento de compilacion en lugar de un valor fijo.
 825:Core/Src/main_unique.c ****  * __DATE__ tiene el formato "Jul 21 2026"; __TIME__ el formato "14:35:07".
 826:Core/Src/main_unique.c ****  * ---------------------------------------------------------------------- */
 827:Core/Src/main_unique.c **** static uint8_t build_month(void)
 828:Core/Src/main_unique.c **** {
