 872:Core/Src/main_unique.c ****     uint32_t prediv_s;        /* prescalador sincrono                  */
 873:Core/Src/main_unique.c **** 
 874:Core/Src/main_unique.c ****     /* --- 1. Seleccion de la fuente de reloj del RTC ---------------------- */
 875:Core/Src/main_unique.c ****     /* Si el cristal LSE arranco se usa el, que es lo que exige el enunciado.
 876:Core/Src/main_unique.c ****        Si no arranco (cristal X2 ausente en la placa) se recurre al LSI para
 877:Core/Src/main_unique.c ****        que el resto del sistema siga siendo utilizable, advirtiendolo por la
 878:Core/Src/main_unique.c ****        consola. El LSI es un oscilador RC interno con una deriva de hasta
 879:Core/Src/main_unique.c ****        +-50 % y, sobre todo, SE DETIENE al perder VDD: con el, la hora no
 880:Core/Src/main_unique.c ****        sobrevive al corte de alimentacion. */
 881:Core/Src/main_unique.c ****     if (system_clock_lse_ok()) {
 882:Core/Src/main_unique.c ****         src_wanted = RCC_RTCCLKSOURCE_LSE;
 883:Core/Src/main_unique.c ****         prediv_a   = 127U;   /* 32768 / 128 = 256 Hz */
 884:Core/Src/main_unique.c ****         prediv_s   = 255U;   /* 256   / 256 = 1 Hz   */
 885:Core/Src/main_unique.c ****     } else {
 886:Core/Src/main_unique.c ****         __HAL_RCC_LSI_ENABLE();
 887:Core/Src/main_unique.c ****         while (__HAL_RCC_GET_FLAG(RCC_FLAG_LSIRDY) == RESET) { }
 888:Core/Src/main_unique.c **** 
 889:Core/Src/main_unique.c ****         src_wanted = RCC_RTCCLKSOURCE_LSI;
 890:Core/Src/main_unique.c ****         prediv_a   = 127U;   /* LSI nominal 32 kHz: 32000 / 128 = 250 Hz */
 891:Core/Src/main_unique.c ****         prediv_s   = 249U;   /* 250 / 250 = 1 Hz (aproximado)            */
 892:Core/Src/main_unique.c **** 
 893:Core/Src/main_unique.c ****         uart_send_line("AVISO: el LSE no arranco. RTC funcionando con LSI.");
 894:Core/Src/main_unique.c ****         uart_send_line("       Revisar el cristal X2 y los puentes SB48/SB49.");
 895:Core/Src/main_unique.c ****     }
 896:Core/Src/main_unique.c **** 
 897:Core/Src/main_unique.c ****     /* Cambiar RTCSEL obliga a un reset del dominio de respaldo, lo que
 898:Core/Src/main_unique.c ****        borraria la hora. Por eso solo se configura si la fuente actual no es
 899:Core/Src/main_unique.c ****        ya la deseada, es decir, unicamente en el primer arranque tras montar
 900:Core/Src/main_unique.c ****        la pila o tras un borrado completo. */
 901:Core/Src/main_unique.c ****     if (__HAL_RCC_GET_RTC_SOURCE() != src_wanted) {
 902:Core/Src/main_unique.c ****         pclk.PeriphClockSelection = RCC_PERIPHCLK_RTC;
 903:Core/Src/main_unique.c ****         pclk.RTCClockSelection    = src_wanted;
