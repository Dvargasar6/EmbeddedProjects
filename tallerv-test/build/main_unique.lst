  53:Core/Src/main_unique.c **** /* --- GPIO: LED de actividad ---------------------------------------------- */
  54:Core/Src/main_unique.c **** #define LED_GPIO_PORT      GPIOH          /* puerto del LED                 */
  55:Core/Src/main_unique.c **** #define LED_PIN            GPIO_PIN_1     /* PH1, impuesto por el enunciado */
  56:Core/Src/main_unique.c **** 
  57:Core/Src/main_unique.c **** /* --- GPIO: pulsador integrado del joystick ------------------------------- */
  58:Core/Src/main_unique.c **** #define JOY_SW_GPIO_PORT   GPIOB          /* puerto del pulsador            */
  59:Core/Src/main_unique.c **** #define JOY_SW_PIN         GPIO_PIN_5     /* PB5 = D4 en el conector Arduino */
  60:Core/Src/main_unique.c **** #define JOY_SW_EXTI_IRQn   EXTI9_5_IRQn   /* las lineas EXTI5..9 comparten IRQ */
  61:Core/Src/main_unique.c **** 
  62:Core/Src/main_unique.c **** /* --- UART ----------------------------------------------------------------- */
  63:Core/Src/main_unique.c **** #define UART_TX_BUF_SIZE   512U           /* potencia de 2: modulo barato    */
  64:Core/Src/main_unique.c **** 
  65:Core/Src/main_unique.c **** /* --- ADC / joystick ------------------------------------------------------- */
  66:Core/Src/main_unique.c **** /* Umbrales sobre la escala de 12 bits (0..4095) del ADC. El centro mecanico
  67:Core/Src/main_unique.c ****    queda proximo a 2048; la banda muerta evita que el ruido genere movimiento. */
  68:Core/Src/main_unique.c **** #define JOY_CENTER         2048U
  69:Core/Src/main_unique.c **** #define JOY_DEADZONE        600U          /* +-600 cuentas alrededor del centro */
  70:Core/Src/main_unique.c **** 
  71:Core/Src/main_unique.c **** /* --- RTC ------------------------------------------------------------------ */
  72:Core/Src/main_unique.c **** /* Firma escrita en el registro de respaldo tras la primera inicializacion:
  73:Core/Src/main_unique.c ****    permite saber si el RTC ya estaba en hora y no reescribirla en cada arranque. */
  74:Core/Src/main_unique.c **** #define RTC_BACKUP_SIGNATURE   0x32F2A5C3U
  75:Core/Src/main_unique.c **** 
  76:Core/Src/main_unique.c **** /* --- LCD ------------------------------------------------------------------ */
