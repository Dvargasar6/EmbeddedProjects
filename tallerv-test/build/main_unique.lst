 222:Core/Src/main_unique.c **** /* ==========================================================================
 223:Core/Src/main_unique.c ****  * 5. MODULO system_clock
 224:Core/Src/main_unique.c ****  *
 225:Core/Src/main_unique.c ****  * Cadena de reloj implementada:
 226:Core/Src/main_unique.c ****  *
 227:Core/Src/main_unique.c ****  *   HSI (16 MHz) --> /PLLM=8 --> 2 MHz --> xPLLN=100 --> VCO 200 MHz
 228:Core/Src/main_unique.c ****  *                                                  --> /PLLP=2 --> 100 MHz = SYSCLK
 229:Core/Src/main_unique.c ****  *
 230:Core/Src/main_unique.c ****  *   AHB  = SYSCLK / 1 = 100 MHz   (limite del F411: 100 MHz)
 231:Core/Src/main_unique.c ****  *   APB1 = SYSCLK / 2 =  50 MHz   (limite del F411:  50 MHz)
 232:Core/Src/main_unique.c ****  *   APB2 = SYSCLK / 1 = 100 MHz   (limite del F411: 100 MHz)
 233:Core/Src/main_unique.c ****  *
 234:Core/Src/main_unique.c ****  * Se elige HSI y no HSE como fuente del PLL por dos razones:
 235:Core/Src/main_unique.c ****  *   1. El LED exigido esta en PH1, que es el pin OSC_OUT del HSE. Usando HSI
 236:Core/Src/main_unique.c ****  *      el puerto GPIOH queda completamente libre.
 237:Core/Src/main_unique.c ****  *   2. En la Nucleo-F411RE el HSE proviene del MCO del ST-LINK (8 MHz) y
 238:Core/Src/main_unique.c ****  *      depende de la configuracion de los puentes SB54/SB55.
 239:Core/Src/main_unique.c ****  * ========================================================================== */
 240:Core/Src/main_unique.c **** 
 241:Core/Src/main_unique.c **** /* Fuente actualmente enrutada a MCO1 */
 242:Core/Src/main_unique.c **** static mco_src_t s_mco_src  = MCO_SRC_PLL;
 243:Core/Src/main_unique.c **** 
 244:Core/Src/main_unique.c **** /* Frecuencia real medida en PA8 tras aplicar el prescaler, en hercios */
 245:Core/Src/main_unique.c **** static uint32_t  s_mco_freq = 20000000U;
 246:Core/Src/main_unique.c **** 
 247:Core/Src/main_unique.c **** /* 1 si el cristal LSE arranco correctamente; 0 si no esta montado o no oscila */
 248:Core/Src/main_unique.c **** static uint8_t   s_lse_ok   = 0;
 249:Core/Src/main_unique.c **** 
 250:Core/Src/main_unique.c **** /*
 251:Core/Src/main_unique.c ****  * system_clock_init
 252:Core/Src/main_unique.c ****  * Configura la alimentacion, la latencia de FLASH, los osciladores y los buses.
 253:Core/Src/main_unique.c ****  * Debe llamarse inmediatamente despues de HAL_Init() y antes de cualquier
 254:Core/Src/main_unique.c ****  * inicializacion de periferico.
 255:Core/Src/main_unique.c ****  */
 256:Core/Src/main_unique.c **** void system_clock_init(void)
 257:Core/Src/main_unique.c **** {
 258:Core/Src/main_unique.c ****     RCC_OscInitTypeDef osc = {0};   /* configuracion de osciladores */
ARM GAS  /tmp/ccjBgtoi.s 			page 6


 259:Core/Src/main_unique.c ****     RCC_ClkInitTypeDef clk = {0};   /* configuracion de buses       */
 260:Core/Src/main_unique.c **** 
 261:Core/Src/main_unique.c ****     /* --- 1. Alimentacion del regulador interno -------------------------- */
 262:Core/Src/main_unique.c ****     /* Habilita el reloj del bloque PWR: sin el no se puede escribir en PWR->CR */
 263:Core/Src/main_unique.c ****     __HAL_RCC_PWR_CLK_ENABLE();
 264:Core/Src/main_unique.c **** 
 265:Core/Src/main_unique.c ****     /* Escala de voltaje 1: unica que admite 100 MHz en el F411.
 266:Core/Src/main_unique.c ****        Alternativas: SCALE2 (hasta 84 MHz) y SCALE3 (hasta 64 MHz), que
 267:Core/Src/main_unique.c ****        consumen menos corriente pero limitan la frecuencia maxima. */
 268:Core/Src/main_unique.c ****     __HAL_PWR_VOLTAGESCALING_CONFIG(PWR_REGULATOR_VOLTAGE_SCALE1);
 269:Core/Src/main_unique.c **** 
 270:Core/Src/main_unique.c ****     /* Permite escribir en el dominio de respaldo (Backup Domain), necesario
 271:Core/Src/main_unique.c ****        para arrancar el LSE y para configurar el RTC. */
 272:Core/Src/main_unique.c ****     HAL_PWR_EnableBkUpAccess();
 273:Core/Src/main_unique.c **** 
 274:Core/Src/main_unique.c ****     /* --- 2. Oscilador HSI y PLL (critico) ------------------------------- */
 275:Core/Src/main_unique.c ****     /* El LSE se configura APARTE, mas abajo. Motivo: muchas placas
 276:Core/Src/main_unique.c ****        NUCLEO-F411RE se sirven sin el cristal X2 de 32.768 kHz montado. Si el
 277:Core/Src/main_unique.c ****        LSE se configurase en la misma llamada, su fallo abortaria tambien la
 278:Core/Src/main_unique.c ****        configuracion del PLL y el sistema entero quedaria detenido en
 279:Core/Src/main_unique.c ****        Error_Handler, sin LCD, sin UART y sin LED de 250 ms. */
 280:Core/Src/main_unique.c ****     osc.OscillatorType      = RCC_OSCILLATORTYPE_HSI;
