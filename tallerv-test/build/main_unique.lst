 444:Core/Src/main_unique.c **** 
 445:Core/Src/main_unique.c ****     /* --- LED en PH1 ----------------------------------------------------- */
 446:Core/Src/main_unique.c ****     /* Estado inicial apagado, escrito antes de configurar el pin como salida
 447:Core/Src/main_unique.c ****        para evitar un pulso espurio al habilitar el driver de salida. */
 448:Core/Src/main_unique.c ****     HAL_GPIO_WritePin(LED_GPIO_PORT, LED_PIN, GPIO_PIN_RESET);
 449:Core/Src/main_unique.c **** 
 450:Core/Src/main_unique.c ****     gi.Pin   = LED_PIN;
 451:Core/Src/main_unique.c ****     gi.Mode  = GPIO_MODE_OUTPUT_PP;  /* push-pull: el pin puede forzar 0 y 1.
 452:Core/Src/main_unique.c ****                                         Alternativa: GPIO_MODE_OUTPUT_OD
 453:Core/Src/main_unique.c ****                                         (drenador abierto), que solo fuerza 0 */
 454:Core/Src/main_unique.c ****     gi.Pull  = GPIO_NOPULL;          /* sin resistencias internas: es salida  */
 455:Core/Src/main_unique.c ****     gi.Speed = GPIO_SPEED_FREQ_LOW;  /* 2 MHz basta para 4 Hz; velocidades
 456:Core/Src/main_unique.c ****                                         mayores solo aumentan el ruido y el
 457:Core/Src/main_unique.c ****                                         consumo. Alternativas: MEDIUM, HIGH,
 458:Core/Src/main_unique.c ****                                         VERY_HIGH */
 459:Core/Src/main_unique.c ****     HAL_GPIO_Init(LED_GPIO_PORT, &gi);
 460:Core/Src/main_unique.c **** 
 461:Core/Src/main_unique.c ****     /* --- Pulsador SW del joystick en PB5 -------------------------------- */
 462:Core/Src/main_unique.c ****     gi.Pin  = JOY_SW_PIN;
 463:Core/Src/main_unique.c ****     gi.Mode = GPIO_MODE_IT_FALLING;  /* interrupcion en flanco de bajada.
 464:Core/Src/main_unique.c ****                                         El SW del joystick cortocircuita el
 465:Core/Src/main_unique.c ****                                         pin a GND al pulsarlo. Alternativas:
