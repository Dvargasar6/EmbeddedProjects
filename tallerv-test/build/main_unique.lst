 387:Core/Src/main_unique.c ****         src = MCO_SRC_PLL;                   /* normaliza el valor guardado  */
 388:Core/Src/main_unique.c ****         break;
 389:Core/Src/main_unique.c ****     }
 390:Core/Src/main_unique.c **** 
 391:Core/Src/main_unique.c ****     s_mco_src = src;   /* memoriza la seleccion para consultarla despues */
 392:Core/Src/main_unique.c **** }
